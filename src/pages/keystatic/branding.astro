---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';
import { GitHubClient } from '~/lib/github';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');
const token = readTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/keystatic/github-token');

const file = 'src/data/site/branding.yaml';

let data: Record<string, any> = {
  site_name: 'Vectoflare',
  logo_image: '',
  logo_alt: 'Vectoflare logo',
  copyright: '© {year} Vectoflare · All rights reserved.',
  whatsapp_number: '',
  whatsapp_default_message: 'Hello, I would like to inquire about your products.',
};
let sha = '';
let loadError: string | null = null;

try {
  const client = new GitHubClient(token);
  const f = await client.readFile(file);
  const yamlMod = await import('js-yaml');
  const parsed = yamlMod.load(f.content) as Record<string, any>;
  if (parsed && typeof parsed === 'object') data = { ...data, ...parsed };
  sha = f.sha;
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Failed to read';
}

const year = new Date().getFullYear();
---
<AdminLayout title="Branding & Logo" active="branding" username={verified?.username}>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Branding & Logo</h1>
    <p class="mt-1 text-sm text-gray-500">Edit site name, logo image, and copyright. File: <code class="font-mono">{file}</code>. You can use <code class="font-mono">{'{year}'}</code> and <code class="font-mono">{'{site_name}'}</code> placeholders in the copyright text, which will be auto-replaced (current year {year}, current site_name "{data.site_name}").</p>
  </div>

  {loadError && (
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 dark:bg-red-950/40 dark:border-red-900 p-3 text-sm text-red-700 dark:text-red-300">
      Failed to read: {loadError}
    </div>
  )}

  <form id="branding-form" class="space-y-6 pb-32" data-file={file} data-sha={sha}>
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Site Name (Logo Text)</label>
        <input
          type="text"
          name="site_name"
          value={data.site_name ?? ''}
          placeholder="Vectoflare"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
        />
        <p class="mt-1 text-xs text-gray-500">Displayed in the top-right logo, bottom footer logo, and copyright. Keep consistent after changes.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Logo Image URL (optional)</label>
        <input
          type="text"
          name="logo_image"
          value={data.logo_image ?? ''}
          placeholder="https://example.com/logo.png"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
        />
        <p class="mt-1 text-xs text-gray-500">Leave empty to use the first letter as a placeholder. Recommended PNG/SVG, square 1:1.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Logo Image Alt Text</label>
        <input
          type="text"
          name="logo_alt"
          value={data.logo_alt ?? ''}
          placeholder="Vectoflare logo"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Copyright (supports HTML tags, e.g. <code class="font-mono">&lt;a class="text-blue-600 underline"&gt;</code>)</label>
        <textarea
          name="copyright"
          rows="3"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
        >{data.copyright ?? ''}</textarea>
        <p class="mt-1 text-xs text-gray-500">Preview (live replacement of <code class="font-mono">{'{year}'}</code>): <span class="font-mono" data-copyright-preview></span></p>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-5">
      <h2 class="text-base font-semibold">WhatsApp Floating Chat</h2>
      <p class="text-xs text-gray-500">WhatsApp chat button in the bottom-right corner. Leave the number empty to hide it.</p>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">WhatsApp Number</label>
        <input
          type="text"
          name="whatsapp_number"
          value={data.whatsapp_number ?? ''}
          placeholder="8613800000000 (with country code, without +)"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Default Message</label>
        <textarea
          name="whatsapp_default_message"
          rows="2"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
        >{data.whatsapp_default_message ?? ''}</textarea>
      </div>
    </div>

    <div class="rounded-xl border border-amber-300 dark:border-amber-800 bg-amber-50 dark:bg-amber-950/30 p-6 space-y-5">
      <div>
        <h2 class="text-base font-semibold text-amber-900 dark:text-amber-200">Contact Form Storage + Email</h2>
        <p class="mt-1 text-xs text-amber-800 dark:text-amber-300">
          <strong>Warning: These fields will be stored in the public repository. Please use a dedicated service account / Fine-grained PAT with Contents: Read and write permission scoped to a single repository.</strong> After configuration, submissions from <code class="font-mono">/contact</code> will be encrypted with AES-256-GCM and written to
          <code class="font-mono">src/data/contact/submissions.enc.json</code> (this file is not indexed by search), and can be viewed at <a class="underline" href="/keystatic/contact-submissions">/keystatic/contact-submissions</a>; email notifications can also be sent via Resend (Reply-to set to the form submitter).
        </p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Recipient Email (Contact email — To)</label>
        <input
          type="email"
          name="contact_email_to"
          value={data.contact_email_to ?? ''}
          placeholder="admin@your-domain.com"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
        />
        <p class="mt-1 text-xs text-gray-500">All contact form submissions will be sent to this email (via Resend). Can also be overridden individually in contact.yaml's contact_form.email_to.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Sender Email (Contact — From)</label>
        <input
          type="email"
          name="contact_from_email"
          value={data.contact_from_email ?? ''}
          placeholder="noreply@your-domain.com"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
        />
        <p class="mt-1 text-xs text-gray-500">SPF/DKIM must be configured on your domain (Cloudflare DNS), otherwise emails will be marked as spam. Recommended: Use Cloudflare Email Routing to route <code class="font-mono">noreply@your-domain.com</code> to your real email, then verify <code class="font-mono">your-domain.com</code> in Resend's Domain settings.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Sender Display Name (From name)</label>
        <input
          type="text"
          name="contact_from_name"
          value={data.contact_from_name ?? ''}
          placeholder="Vectoflare Contact"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email Service Provider</label>
        <select
          name="contact_email_provider"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
        >
          <option value="none" selected={!data.contact_email_provider || data.contact_email_provider === 'none'}>Do not send email (only store to GitHub)</option>
          <option value="resend" selected={data.contact_email_provider === 'resend'}>Resend (Recommended · Free 100/day · Cloudflare compatible)</option>
        </select>
        <p class="mt-1 text-xs text-gray-500">Cloudflare Email Workers can only handle <strong>inbound</strong> emails, not send arbitrary outbound mail. Resend is a Cloudflare Pages-compatible sending service. If you want to use SMTP instead, you can replace <code class="font-mono">sendEmailViaResend</code> in <code class="font-mono">src/pages/api/contact.ts</code>.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Resend API Key</label>
        <input
          type="password"
          name="contact_resend_api_key"
          value={data.contact_resend_api_key ?? ''}
          placeholder="re_xxx"
          autocomplete="off"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
        />
        <p class="mt-1 text-xs text-gray-500">Create at <a class="underline" href="https://resend.com/api-keys" target="_blank" rel="noopener">resend.com/api-keys</a>. Full access permission is sufficient.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">GitHub PAT (for writing encrypted storage, service account)</label>
        <input
          type="password"
          name="contact_submissions_pat"
          value={data.contact_submissions_pat ?? ''}
          placeholder="github_pat_xxx or ghp_xxx"
          autocomplete="off"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
        />
        <p class="mt-1 text-xs text-amber-800 dark:text-amber-300">
          <strong>Fine-grained PAT required</strong> (create at GitHub Settings → Developer settings → Personal access tokens → Fine-grained tokens), only check <strong>Contents: Read and write</strong> permission for the <code class="font-mono">theworkvigour/astro_Tina-CMS</code> repository. Classic PATs have full repository permissions, and the consequences of leakage are more severe.
        </p>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50 p-4">
      <div class="text-xs text-gray-500 mb-2">Current Logo Preview (live)</div>
      <div class="flex items-center gap-2" data-logo-preview>
        {data.logo_image ? (
          <img src={data.logo_image} alt={data.logo_alt} class="h-9 w-9 rounded-lg object-cover shadow-sm" data-preview-img />
        ) : (
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-sky-500 to-blue-600 text-white font-black text-lg shadow-sm" data-preview-letter>{(data.site_name || 'V').charAt(0).toUpperCase()}</span>
        )}
        <span class="self-center text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white tracking-tight" data-preview-name>{data.site_name}</span>
      </div>
      <p class="mt-2 text-xs text-gray-500">The footer logo text will display the same site_name.</p>
    </div>

    <div class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 z-40">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <div class="text-xs text-gray-500" data-fileInfo>File: <code class="font-mono">{file}</code></div>
        <div class="flex gap-2">
          <a href="/keystatic" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline">Cancel</a>
          <button id="submit-btn" type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md">Save & Push</button>
        </div>
      </div>
    </div>
  </form>

  <script is:inline>
    (function () {
      const form = document.getElementById('branding-form');
      if (!form) return;
      const submitBtn = document.getElementById('submit-btn');
      const file = form.dataset.file;
      const sha = form.dataset.sha;
      const year = new Date().getFullYear();
      const siteNameEl = form.querySelector('[name="site_name"]');
      const logoImageEl = form.querySelector('[name="logo_image"]');
      const copyrightEl = form.querySelector('[name="copyright"]');
      const previewEl = form.querySelector('[data-copyright-preview]');
      const previewName = form.querySelector('[data-preview-name]');
      const previewImg = form.querySelector('[data-preview-img]');
      const previewLetter = form.querySelector('[data-preview-letter]');
      const previewWrap = form.querySelector('[data-logo-preview]');

      function refreshCopyright() {
        if (copyrightEl instanceof HTMLTextAreaElement && previewEl) {
          const name = siteNameEl instanceof HTMLInputElement ? (siteNameEl.value || 'Vectoflare').trim() || 'Vectoflare' : 'Vectoflare';
          previewEl.textContent = (copyrightEl.value || '')
            .replace(/\\{year\\}/gi, String(year))
            .replace(/\\{site_name\\}/gi, name);
        }
      }
      function refreshName() {
        const name = siteNameEl instanceof HTMLInputElement ? (siteNameEl.value || 'V').trim() || 'V' : 'V';
        if (previewName) previewName.textContent = name;
        if (previewLetter) previewLetter.textContent = name.charAt(0).toUpperCase();
      }
      function refreshLogo() {
        const url = logoImageEl instanceof HTMLInputElement ? (logoImageEl.value || '').trim() : '';
        if (!previewWrap) return;
        if (url) {
          if (previewImg) {
            previewImg.src = url;
          } else if (previewLetter && previewLetter.parentNode) {
            const img = document.createElement('img');
            img.src = url;
            img.alt = '';
            img.className = 'h-9 w-9 rounded-lg object-cover shadow-sm';
            img.setAttribute('data-preview-img', '');
            previewLetter.parentNode.replaceChild(img, previewLetter);
          }
        } else {
          if (previewImg) {
            const name = siteNameEl instanceof HTMLInputElement ? (siteNameEl.value || 'V').charAt(0).toUpperCase() : 'V';
            const span = document.createElement('span');
            span.className = 'inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-sky-500 to-blue-600 text-white font-black text-lg shadow-sm';
            span.setAttribute('data-preview-letter', '');
            span.textContent = name;
            previewImg.parentNode.replaceChild(span, previewImg);
          }
        }
      }
      function refreshAll() { refreshCopyright(); refreshName(); refreshLogo(); }
      if (siteNameEl) siteNameEl.addEventListener('input', refreshAll);
      if (logoImageEl) logoImageEl.addEventListener('input', refreshAll);
      if (copyrightEl) copyrightEl.addEventListener('input', refreshCopyright);
      refreshAll();

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Pushing...'; }

        const fd = new FormData(form);
        const data = {
          site_name: String(fd.get('site_name') || '').trim(),
          logo_image: String(fd.get('logo_image') || '').trim(),
          logo_alt: String(fd.get('logo_alt') || '').trim(),
          copyright: String(fd.get('copyright') || ''),
          whatsapp_number: String(fd.get('whatsapp_number') || '').trim(),
          whatsapp_default_message: String(fd.get('whatsapp_default_message') || ''),
          contact_email_to: String(fd.get('contact_email_to') || '').trim(),
          contact_email_provider: String(fd.get('contact_email_provider') || 'none'),
          contact_from_email: String(fd.get('contact_from_email') || '').trim(),
          contact_from_name: String(fd.get('contact_from_name') || '').trim(),
          contact_resend_api_key: String(fd.get('contact_resend_api_key') || '').trim(),
          contact_submissions_pat: String(fd.get('contact_submissions_pat') || '').trim(),
        };

        try {
          const res = await fetch('/api/admin/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              format: 'yaml',
              path: file,
              sha,
              data,
              commitMessage: 'Update site branding and copyright',
            }),
          });
          const result = await res.json();
          if (!res.ok || !result.success) {
            window.__adminToast?.(result.error || 'Save failed', 'error');
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Save & Push'; }
            return;
          }
          window.__adminToast?.('Saved, Cloudflare is redeploying...', 'success');
          setTimeout(() => { window.location.reload(); }, 800);
        } catch {
          window.__adminToast?.('Network error', 'error');
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Save & Push'; }
        }
      });
    })();
  </script>
</AdminLayout>
