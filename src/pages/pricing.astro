---
import { getEntry } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { SITE, I18N } from 'astrowind:config';

import yamlData from '~/data/pages/pricing.yaml';

const locale = I18N?.language || 'en';
const entry = await getEntry('pricing', 'index');
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const ksData = (entry?.data as any)?.[locale] || (entry?.data as any)?.['en'] || {};
const data = Object.keys(ksData).length > 0 ? ksData : yamlData;

const ht = data.hero_text ?? {};
const pkg = data.pricing_packages ?? {};
const incl = data.features3_included ?? {};
const proc = data.steps_process ?? {};
const faqs = data.faqs ?? {};
const cta = data.cta ?? {};

const metadata = {
  title: `Pricing — Inflatable Boats, RIBs & Service Packages | ${SITE.name}`,
  description: `Transparent pricing for ${SITE.name} boats, accessories and service packages. No hidden fees. Request a quote or order now.`,
};

const crumbs = [{ name: 'Home', href: '/' }, { name: 'Pricing' }];

const faqSchemaItems = (faqs?.items ?? [])
  .filter((item: any) => item?.title && item?.description)
  .map((item: any) => ({
    '@type': 'Question',
    name: item.title,
    acceptedAnswer: { '@type': 'Answer', text: item.description },
  }));

const faqJsonLd = faqSchemaItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqSchemaItems,
} : null;
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
  <HeroText tagline={ht.tagline} title={ht.title} subtitle={ht.subtitle} />

  <Prices title={pkg.title} subtitle={pkg.subtitle} prices={pkg.prices} />

  <Features3
    title={incl.title}
    subtitle={incl.subtitle}
    columns={incl.columns}
    items={incl.items}
  />

  <Steps
    title={proc.title}
    tagline={proc.tagline}
    isReversed={proc.isReversed}
    items={proc.items}
    image={proc.image}
  />

  <FAQs title={faqs.title} subtitle={faqs.subtitle} columns={faqs.columns} items={faqs.items} />

  <CallToAction
    title={cta.title}
    subtitle={cta.subtitle}
    actions={cta.actions}
  />
</Layout>
