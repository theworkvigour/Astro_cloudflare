---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Become a Wavefella Partner — ' + SITE.name,
  description: 'Global distributor and partnership opportunities with Wavefella water sports equipment.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto py-20 px-6">
    <div class="text-center">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Partnership</span>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-gray-900">Become a Wavefella Partner</h1>
      <p class="mt-6 text-lg text-gray-500 max-w-2xl mx-auto">
        We work with global distributors in water sports retail, rental operations,
        and marine equipment supply. Join our network.
      </p>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-8">
      <div class="border border-gray-200 rounded-2xl p-6">
        <h2 class="font-semibold text-gray-900">Distributors</h2>
        <p class="text-gray-500 mt-2 text-sm">Authorized resellers for retail and e-commerce channels worldwide.</p>
      </div>
      <div class="border border-gray-200 rounded-2xl p-6">
        <h2 class="font-semibold text-gray-900">Rental Operators</h2>
        <p class="text-gray-500 mt-2 text-sm">Bulk supply for water sports rental businesses, resorts, and tour operators.</p>
      </div>
      <div class="border border-gray-200 rounded-2xl p-6">
        <h2 class="font-semibold text-gray-900">Institutional</h2>
        <p class="text-gray-500 mt-2 text-sm">Government, rescue, and commercial fleet procurement programs.</p>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a href="/contact" class="inline-block px-8 py-4 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors">
        Apply for partnership
      </a>
    </div>
  </section>
</Layout>
