---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `Guides — ${SITE.name}`,
  description: 'Beginner guides for SUP and water sports. Learn how to choose your SUP, safety tips, inflatable vs hard board comparisons, and paddling techniques.',
};

const guides = [
  {
    title: 'How to Choose Your SUP',
    desc: 'Length, width, volume, and shape — understand what each spec means and find the right board for your weight, skill level, and water type.',
    icon: '🤔',
    slug: 'how-to-choose-your-sup',
  },
  {
    title: 'Beginner\'s Guide to Paddling',
    desc: 'Step-by-step guide for first-time paddlers. Stance, stroke technique, turning, and safety checks before you launch.',
    icon: '📖',
    slug: 'beginner-guide',
  },
  {
    title: 'Inflatable vs Hard Board',
    desc: 'Compare portability, durability, performance, storage, and cost between inflatable drop-stitch boards and rigid epoxy/fiberglass boards.',
    icon: '⚖️',
    slug: 'inflatable-vs-hard',
  },
  {
    title: 'Water Safety Tips',
    desc: 'Essential safety practices for paddling: weather checks, PFD selection, leash use, cold water awareness, and navigation rules.',
    icon: '🛡️',
    slug: 'safety-tips',
  },
  {
    title: 'SUP Maintenance & Storage',
    desc: 'Clean, store, and maintain your inflatable SUP. UV protection, valve care, pressure management, and puncture repair.',
    icon: '🔧',
    slug: 'sup-maintenance',
  },
  {
    title: 'SUP Paddling Techniques',
    desc: 'Master forward stroke, sweep turn, reverse stroke, cross-bow turn, and bracing for efficient and confident paddling.',
    icon: '🏄',
    slug: 'paddling-techniques',
  },
  {
    title: 'SUP Fishing Guide',
    desc: 'Select a board, set up gear, and master casting and landing techniques for stand-up paddleboard fishing.',
    icon: '🎣',
    slug: 'sup-fishing',
  },
  {
    title: 'SUP Yoga Guide',
    desc: 'Practice yoga on water. Board selection, beginner to advanced poses, anchoring, and the benefits of SUP yoga.',
    icon: '🧘',
    slug: 'sup-yoga',
  },
  {
    title: 'Choosing the Right Paddle',
    desc: 'Material, length, blade shape, and shaft type — find the perfect paddle for your height, strength, and paddling style.',
    icon: '🏏',
    slug: 'choosing-paddle',
  },
  {
    title: 'SUP for Fitness & Training',
    desc: 'Full-body workout routines, interval training, endurance paddling, and cross-training with SUP yoga.',
    icon: '💪',
    slug: 'sup-fitness',
  },
  {
    title: 'Kayak Paddling Techniques',
    desc: 'Forward stroke, sweep turn, draw stroke, and tandem paddling techniques for inflatable kayaks.',
    icon: '🛶',
    slug: 'kayak-techniques',
  },
  {
    title: 'Weather & Water Conditions',
    desc: 'Read wind, waves, tides, and currents. Make safe go/no-go decisions for every paddling outing.',
    icon: '🌤️',
    slug: 'weather-conditions',
  },
  {
    title: 'Inflatable Care & Repair',
    desc: 'Find leaks, repair punctures, replace valves, and maintain your inflatable SUP, kayak, or boat.',
    icon: '🩹',
    slug: 'inflatable-repair',
  },
  {
    title: 'SUP & Kayaking with Kids',
    desc: 'Age recommendations, safety gear, best boards for families, and tips for keeping young paddlers engaged.',
    icon: '👨‍👩‍👧‍👦',
    slug: 'sup-with-kids',
  },
  {
    title: 'Multi-Day Trip Planning',
    desc: 'Plan expeditions with gear checklists, route planning, food and water, and Leave No Trace principles.',
    icon: '🎒',
    slug: 'multi-day-trip',
  },
  {
    title: 'Understanding SUP Specs',
    desc: 'Decode volume, length, width, thickness, hull shape, and weight capacity — explained for every paddler.',
    icon: '📐',
    slug: 'understanding-specs',
  },
];
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="beginner-water-sports-guides,sup-selection-guide,paddling-safety" />

  <section class="max-w-4xl mx-auto py-24 px-6" data-ai-block="definition">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Guides</span>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">New to SUP?</h1>
    <p class="mt-4 text-lg text-gray-500">Practical guides to help you choose, use, and enjoy inflatable water sports equipment.</p>
  </section>

  <section class="max-w-4xl mx-auto pb-24 px-6">
    <div class="grid md:grid-cols-2 gap-6">
      {guides.map(g => (
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-xl">{g.icon}</div>
          <h2 class="mt-4 text-xl font-semibold text-gray-900">{g.title}</h2>
          <p class="mt-2 text-gray-500 text-sm">{g.desc}</p>
          <a href={`/guides/${g.slug}`} class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">Read guide →</a>
        </div>
      ))}
    </div>
  </section>

  <section class="sr-only" data-ai-block="use-case" aria-hidden="true">
    <p>Wavefella guides cover beginner SUP selection, paddling technique, equipment comparison, water safety, maintenance, fishing, yoga, fitness, kayaking, weather reading, repair, family paddling, trip planning, and board specifications for recreational users.</p>
  </section>
</Layout>
