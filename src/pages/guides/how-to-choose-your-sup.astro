---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { products } from '../../data/products';
import JsonLd from '~/components/common/JsonLd.astro';

const metadata = {
  title: `How to Choose Your SUP — ${SITE.name}`,
  description: 'Learn how to choose the right inflatable SUP board based on length, width, volume, skill level, and water environment.',
};
const sups = products.filter(p => p.category === 'SUP');
---

<Layout metadata={metadata}>
  <JsonLd type="Article" article={{
    headline: 'How to Choose Your SUP Board',
    description: 'Learn how to choose the right inflatable SUP board based on length, width, volume, skill level, and water environment.',
    datePublished: '2025-01-10',
  }} data={{ url: 'https://alluredna.com/guides/how-to-choose-your-sup' }} />
  <JsonLd type="HowTo" howto={{
    name: 'How to Choose Your SUP',
    description: 'Select the right inflatable SUP board for your needs.',
    steps: [
      { name: 'Choose Length', text: 'Longer boards 11-12 ft track straighter for touring. Shorter boards 9-10 ft turn faster for surfing and maneuvering.' },
      { name: 'Choose Width', text: 'Wider boards 32-34 in offer stability for beginners. Narrower boards 28-30 in are faster but require better balance.' },
      { name: 'Match Skill Level', text: 'Wavefella offers boards for all levels from beginner to professional. Match the board specs to your experience.' },
    ],
  }} />
  <section class="max-w-3xl mx-auto py-24 px-6" data-ai-block="definition">
    <a href="/guides" class="text-sm text-sky-600 hover:text-sky-700">← Guides</a>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">How to Choose Your SUP</h1>
    <p class="mt-4 text-lg text-gray-500">The right SUP depends on your weight, skill level, and where you paddle. Here is how to match the specs to your needs.</p>

    <div class="mt-12 space-y-12">
      <section>
        <h2 class="text-2xl font-semibold text-gray-900">Length</h2>
        <p class="mt-3 text-gray-600">Longer boards (11-12 ft) track straighter and glide farther — ideal for touring and fitness. Shorter boards (9-10 ft) turn faster — better for surfing and maneuvering.</p>
      </section>
      <section>
        <h2 class="text-2xl font-semibold text-gray-900">Width</h2>
        <p class="mt-3 text-gray-600">Wider boards (32-34 in) offer more stability for beginners and yoga. Narrower boards (28-30 in) are faster but require better balance.</p>
      </section>
      <section>
        <h2 class="text-2xl font-semibold text-gray-900">Skill Level Match</h2>
        <p class="mt-3 text-gray-600">Wavefella designs boards for all levels:</p>
        <ul class="mt-3 space-y-2 text-gray-600">
          {sups.map(s => (
            <li class="flex items-start gap-2"><span class="text-sky-600 mt-1">•</span><span><strong>{s.name}</strong> — {s.skill}. {s.ai_comparison}</span></li>
          ))}
        </ul>
      </section>
    </div>

    <section class="mt-12 p-6 bg-sky-50 rounded-2xl border border-sky-100">
      <h2 class="font-semibold text-gray-900">Related</h2>
      <div class="mt-3 flex flex-wrap gap-3 text-sm">
        <a href="/guides/beginner-guide" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">Beginner Guide</a>
        <a href="/guides/inflatable-vs-hard" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">Inflatable vs Hard Board</a>
        <a href="/guides/safety-tips" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">Safety Tips</a>
        <a href="/technology" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">Technology</a>
      </div>
    </section>
  </section>
</Layout>
