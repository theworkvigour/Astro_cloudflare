---
export const prerender = false;

import Layout from '~/layouts/PageLayout.astro';

const q = Astro.url.searchParams.get('q') || '';
---

<Layout metadata={{ title: q ? `Search: ${q}` : 'Search' }}>
  <section class="max-w-5xl mx-auto px-4 py-12 md:py-20">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">Search</h1>
      <form method="get" action="/search" class="flex gap-2">
        <input
          type="text"
          name="q"
          value={q}
          placeholder="Search posts, products, guides..."
          class="flex-1 px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
        />
        <button
          type="submit"
          class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition"
        >Search</button>
      </form>
    </div>

    <div id="search-filters" class="hidden mb-6 flex flex-wrap gap-2" data-search-filters></div>
    <div id="search-results" class="space-y-4">
      {q && (
        <p class="text-gray-500 dark:text-gray-400" id="loading">Searching...</p>
      )}
      {!q && (
        <p class="text-gray-500 dark:text-gray-400">Enter a keyword to search.</p>
      )}
    </div>
  </section>

  {q && (
    <script>
      (async function () {
        var q = new URLSearchParams(location.search).get('q') || '';
        var res = await fetch('/search-index.json');
        if (!res.ok) return;
        var index = await res.json();
        var lower = q.toLowerCase();

        function highlight(s) {
          if (!s || !lower) return s || '';
          var idx = s.toLowerCase().indexOf(lower);
          if (idx === -1) return escapeHtml(s);
          return escapeHtml(s.slice(0, idx)) + '<mark class="bg-yellow-200 dark:bg-yellow-700/60 text-inherit rounded-sm px-0.5">' + escapeHtml(s.slice(idx, idx + lower.length)) + '</mark>' + escapeHtml(s.slice(idx + lower.length));
        }

        function typeBadge(type) {
          var colors = {
            product: 'bg-blue-100 text-blue-700 dark:bg-blue-900/50 dark:text-blue-300',
            article: 'bg-green-100 text-green-700 dark:bg-green-900/50 dark:text-green-300',
            guide: 'bg-purple-100 text-purple-700 dark:bg-purple-900/50 dark:text-purple-300',
            page: 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400',
          };
          var c = colors[type] || colors.page;
          return '<span class="text-[11px] font-medium uppercase tracking-wider px-2 py-0.5 rounded-full ' + c + '">' + escapeHtml(type) + '</span>';
        }

        var matches = index.filter(function (it) {
          return (it.title || '').toLowerCase().includes(lower) ||
                 (it.excerpt || '').toLowerCase().includes(lower) ||
                 (it.tags || []).some(function (t) { return String(t).toLowerCase().includes(lower); });
        });

        var types = {};
        matches.forEach(function (m) { types[m.type] = (types[m.type] || 0) + 1; });
        var typeKeys = Object.keys(types);

        var container = document.getElementById('search-results');
        var filterBar = document.getElementById('search-filters');
        if (!container) return;
        document.getElementById('loading')?.remove();

        if (matches.length === 0) {
          container.innerHTML = '<div class="py-12 text-center"><p class="text-gray-500 dark:text-gray-400 text-lg">No results found for <strong>' + escapeHtml(q) + '</strong>.</p><p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Try a different keyword or browse <a href="/guides" class="text-sky-600 hover:underline">guides</a> or <a href="/products" class="text-sky-600 hover:underline">products</a>.</p></div>';
          filterBar!.classList.add('hidden');
          return;
        }

        var activeFilter = '';
        filterBar!.classList.remove('hidden');
        filterBar!.innerHTML = typeKeys.map(function (t) {
          var label = t.charAt(0).toUpperCase() + t.slice(1) + 's';
          var count = types[t];
          var isActive = activeFilter === t;
          return '<button data-filter="' + t + '" class="px-3 py-1.5 text-xs font-medium rounded-full border transition ' + (isActive ? 'bg-gray-900 text-white dark:bg-white dark:text-gray-900 border-gray-900 dark:border-white' : 'bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 border-gray-300 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500') + '">' + label + ' (' + count + ')</button>';
        }).join('');

        function render(filter) {
          var filtered = filter ? matches.filter(function (m) { return m.type === filter; }) : matches;
          container!.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400 mb-4">' + filtered.length + ' result' + (filtered.length !== 1 ? 's' : '') + ' for <strong>' + escapeHtml(q) + '</strong></p>'
            + filtered.map(function (m) {
              var img = m.image ? '<div class="shrink-0 w-16 h-16 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-700"><img src="' + escapeAttr(m.image) + '" alt="" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display=\'none\'"></div>' : '';
              var priceHtml = (m.price && m.currency === 'USD') ? '<span class="text-sm font-semibold text-gray-900 dark:text-white">$' + escapeHtml(String(m.price)) + '</span>' : '';
              return '<a href="' + escapeAttr(m.url) + '" class="flex gap-4 p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-750 transition">'
                + img
                + '<div class="min-w-0 flex-1">'
                + '<div class="flex items-center gap-2 mb-1 flex-wrap">' + typeBadge(m.type) + '<h2 class="text-base font-semibold text-gray-900 dark:text-white truncate">' + highlight(m.title) + '</h2></div>'
                + (m.excerpt ? '<p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2">' + highlight(m.excerpt) + '</p>' : '')
                + (priceHtml ? '<div class="mt-1">' + priceHtml + '</div>' : '')
                + '</div>'
                + '</a>';
            }).join('');
        }

        render(activeFilter);

        filterBar!.addEventListener('click', function (e) {
          var btn = e.target instanceof Element ? e.target.closest('[data-filter]') : null;
          if (!btn) return;
          var t = btn.getAttribute('data-filter');
          activeFilter = activeFilter === t ? '' : (t ?? '');
          filterBar!.querySelectorAll('[data-filter]').forEach(function (b) {
            var isActive = b.getAttribute('data-filter') === activeFilter;
            b.className = 'px-3 py-1.5 text-xs font-medium rounded-full border transition ' + (isActive ? 'bg-gray-900 text-white dark:bg-white dark:text-gray-900 border-gray-900 dark:border-white' : 'bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 border-gray-300 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500');
          });
          render(activeFilter);
        });

        function escapeHtml(s) {
          return String(s).replace(/[&<>"']/g, function (c) {
            return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&#39;', "'": '&#39;' })[c] || '';
          });
        }
        function escapeAttr(s) { return escapeHtml(s); }
      })();
    </script>
  )}
</Layout>
