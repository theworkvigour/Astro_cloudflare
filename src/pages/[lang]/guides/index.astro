---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import JsonLd from '~/components/common/JsonLd.astro';
import { guides } from '~/data/guides';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;
const metadata = {
  title: `Guides — ${SITE.name}`,
  description: 'Beginner guides for SUP and water sports. Learn how to choose your SUP, safety tips, inflatable vs hard board comparisons, paddling techniques, and more.',
};

const categories = [...new Set(guides.map(g => g.category))];
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="beginner-water-sports-guides,sup-selection-guide,paddling-safety" />
  <JsonLd type="WebSite" data={{
    name: 'Wavefella Guides',
    description: 'Water sports guides and tutorials',
  }} />

  <section class="max-w-4xl mx-auto py-24 px-6" data-ai-block="definition">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{t('guides.pageLabel')}</span>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">{t('guides.pageTitle')}</h1>
    <p class="mt-4 text-lg text-gray-500">{t('guides.pageDesc')}</p>
    <div class="mt-6 flex flex-wrap gap-2 text-xs">
      <span class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full font-medium">{t('guides.count').replace('{count}', String(guides.length))}</span>
      <span class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full font-medium">{t('guides.categories').replace('{count}', String(categories.length))}</span>
    </div>
  </section>

  <section class="max-w-4xl mx-auto pb-8 px-6">
    <div class="p-6 bg-gradient-to-r from-sky-50 to-blue-50 border border-sky-100 rounded-2xl">
      <h2 class="text-lg font-semibold text-gray-900">{t('guides.surfingCta')}</h2>
      <p class="mt-1 text-sm text-gray-500">{t('guides.surfingDesc')}</p>
      <a href={`/${lang}/v2`} class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">{t('guides.browseSurfing')}</a>
    </div>
  </section>

  {categories.map(cat => (
    <section class="max-w-4xl mx-auto pb-16 px-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-6">{t('guides.category.' + cat.replace(/-/g, '_')) || cat}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {guides.filter(g => g.category === cat).map(g => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center gap-2 text-xs mb-3">
              <span class="px-2 py-0.5 bg-sky-50 text-sky-700 rounded-full capitalize">{g.difficulty}</span>
              {g.waterType.slice(0, 2).map(w => <span class="px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full">{w}</span>)}
            </div>
            <h3 class="text-xl font-semibold text-gray-900">{g.title}</h3>
            <p class="mt-2 text-gray-500 text-sm">{g.description}</p>
            <a href={`/${lang}/guides/${g.slug}`} class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">{t('guides.readGuide')}</a>
          </div>
        ))}
      </div>
    </section>
  ))}
</Layout>
