---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import JsonLd from '~/components/common/JsonLd.astro';
import Tldr from '~/components/common/Tldr.astro';
import { guides } from '~/data/guides';
import { products } from '~/data/products';
import { languages } from '~/i18n/config';

export async function getStaticPaths() {
  const paths: Array<{ params: { lang: string; slug: string }; props: { guide: typeof guides[number] } }> = [];
  for (const lang of Object.keys(languages)) {
    for (const guide of guides) {
      paths.push({ params: { lang, slug: guide.slug }, props: { guide } });
    }
  }
  return paths;
}

const { guide } = Astro.props;
const { lang } = Astro.params;

const relatedProducts = guide.relatedProducts
  .map(id => products.find(p => p.id === id))
  .filter(Boolean);

const relatedGuides = guide.relatedGuides
  .map(slug => guides.find(g => g.slug === slug))
  .filter(Boolean);

const metadata = {
  title: `${guide.title} — ${SITE.name}`,
  description: guide.description,
};
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content={`${guide.category},${guide.waterType.join(',')},${guide.difficulty}`} />

  <article class="max-w-3xl mx-auto py-24 px-6" data-ai-block="definition">
    <a href={`/${lang}/guides`} class="text-sm text-sky-600 hover:text-sky-700">← Guides</a>

    <h1 class="mt-4 text-4xl font-semibold text-gray-900">{guide.title}</h1>
    <p class="mt-4 text-lg text-gray-500">{guide.description}</p>

    <div class="mt-4 flex flex-wrap gap-2 text-xs">
      <span class="px-2.5 py-1 bg-sky-50 text-sky-700 rounded-full font-medium capitalize">{guide.category.replace('-', ' ')}</span>
      <span class="px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full capitalize">{guide.difficulty}</span>
      {guide.waterType.map(w => <span class="px-2.5 py-1 bg-gray-100 text-gray-500 rounded-full">{w}</span>)}
    </div>

    <Tldr summary={guide.tldr} className="mt-8" />

    <section class="mt-12 space-y-12" data-ai-block="content">
      <section data-ai-block="problem">
        <h2 class="text-2xl font-semibold text-gray-900">The challenge</h2>
        <p class="mt-3 text-gray-600 leading-relaxed">{guide.problem}</p>
      </section>

      <section data-ai-block="solution">
        <h2 class="text-2xl font-semibold text-gray-900">The solution</h2>
        <p class="mt-3 text-gray-600 leading-relaxed">{guide.solution}</p>
        <p class="mt-2 text-sm text-gray-500">Audience: {guide.audience}</p>
      </section>

      {guide.steps.length > 0 && (
        <section data-ai-block="steps">
          <h2 class="text-2xl font-semibold text-gray-900">Steps</h2>
          <ol class="mt-6 space-y-6">
            {guide.steps.map((step, i) => (
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-8 h-8 bg-sky-100 text-sky-700 rounded-full flex items-center justify-center text-sm font-bold">{i + 1}</span>
                <p class="mt-1 text-gray-600 leading-relaxed">{step}</p>
              </li>
            ))}
          </ol>
        </section>
      )}
    </section>

    {guide.faq.length > 0 && (
      <section class="mt-16" data-ai-block="faq">
        <h2 class="text-2xl font-semibold text-gray-900">FAQ</h2>
        <div class="mt-6 space-y-4">
          {guide.faq.map(item => (
            <details class="bg-white border border-gray-200 rounded-xl overflow-hidden group">
              <summary class="px-6 py-4 font-semibold text-gray-900 cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                <span>{item.q}</span>
                <span class="text-gray-400 group-open:rotate-180 transition-transform shrink-0">▼</span>
              </summary>
              <div class="px-6 pb-4">
                <p class="text-gray-600 leading-relaxed">{item.a}</p>
              </div>
            </details>
          ))}
        </div>
      </section>
    )}

    <JsonLd type="FAQPage" faqs={guide.faq.map(f => ({ q: f.q, a: f.a }))} />
    <JsonLd type="Article" article={{
      headline: guide.title,
      description: guide.description,
    }} data={{ url: `${SITE.site}/${lang}/guides/${guide.slug}` }} />

    {(relatedProducts.length > 0 || relatedGuides.length > 0) && (
      <section class="mt-16 p-8 bg-gray-50 rounded-2xl border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">Related</h2>
        <div class="mt-6 flex flex-wrap gap-4">
          {relatedProducts.map(p => (
            <a href={`/${lang}/products/${p.id}`} class="px-4 py-2 bg-white rounded-xl border border-gray-200 text-sm text-gray-700 hover:border-sky-300 hover:text-sky-700 transition-colors font-medium">
              {p.name} →
            </a>
          ))}
          {relatedGuides.map(g => (
            <a href={`/${lang}/guides/${g.slug}`} class="px-4 py-2 bg-white rounded-xl border border-gray-200 text-sm text-gray-700 hover:border-sky-300 hover:text-sky-700 transition-colors">
              {g.title} →
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>
