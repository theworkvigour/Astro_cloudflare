---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import { getLangFromUrl } from '~/i18n/utils';
import { languages } from '~/i18n/config';
import { articleSchema } from '~/lib/seo/schema';
import { getPageContent } from '~/i18n/page-content';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const page = getPageContent(lang, 'inflatable-vs-hardboard');

const faqEntities = (page.faqs || []).map((f: { question: string; answer: string }) => ({
  '@type': 'Question',
  name: f.question,
  acceptedAnswer: { '@type': 'Answer', text: f.answer },
}));

const graphJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    articleSchema({
      headline: page.seo?.headline || 'Inflatable SUP vs Hard Board: Complete Comparison Guide',
      description: page.seo?.description || 'Compare inflatable SUPs and hard paddle boards across portability, durability, performance, and use cases to find the right board for your needs.',
      datePublished: page.seo?.datePublished || '2024-02-10',
      dateModified: page.seo?.dateModified || '2026-06-01',
      author: 'Wavefella',
      publisher: 'Wavefella',
    }),
    {
      '@type': 'FAQPage',
      mainEntity: faqEntities,
    },
  ],
};
---

<PageLayout>
  <script slot="before" is:inline type="application/ld+json" set:html={JSON.stringify(graphJsonLd)} />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{page.label || 'Compare'}</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">{page.headline || 'Inflatable SUP vs Hard Board: Which One Is Right for You?'}</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">{page.subtitle || 'An in-depth comparison of inflatable and hard stand-up paddle boards across portability, durability, performance, and use cases.'}</p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none" set:html={page.body || ''}>
    </div>
  </section>
</PageLayout>
