---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import { getLangFromUrl } from '~/i18n/utils';
import { languages } from '~/i18n/config';
import { nodes } from '~/content/graph/nodes';
import { articleSchema } from '~/lib/seo/schema';
import { getPageContent } from '~/i18n/page-content';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const page = getPageContent(lang, 'what-is-sup');
const supNode = nodes.find(n => n.id === 'inflatable-sup');

const graphJsonLd = supNode ? {
  '@context': 'https://schema.org',
  '@graph': [
    articleSchema({
      headline: page.seo?.headline || 'What is an Inflatable SUP Board?',
      description: page.seo?.description || 'Complete guide to inflatable stand-up paddle boards: construction, technology, uses, and how they compare to hard boards.',
      datePublished: page.seo?.datePublished || '2024-01-15',
      dateModified: page.seo?.dateModified || '2026-06-01',
      author: 'Wavefella',
      publisher: 'Wavefella',
    }),
    {
      '@type': 'Product',
      name: supNode.name.en,
      description: supNode.description.en,
      brand: { '@type': 'Brand', name: 'Wavefella' },
      category: 'Water Sports Equipment',
    },
  ],
} : null;
---

<PageLayout>
  <script slot="before" is:inline type="application/ld+json" set:html={graphJsonLd ? JSON.stringify(graphJsonLd) : ''} />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{page.label || 'Guide'}</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">{page.headline || 'What is an Inflatable SUP Board?'}</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">{page.subtitle || 'A complete guide to understanding inflatable stand-up paddle boards — construction, technology, and how to choose.'}</p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none" set:html={page.body || ''}>
    </div>
  </section>
</PageLayout>
