---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import { getLangFromUrl } from '~/i18n/utils';
import { languages } from '~/i18n/config';
import { nodes } from '~/content/graph/nodes';
import { articleSchema } from '~/lib/seo/schema';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const supNode = nodes.find(n => n.id === 'inflatable-sup');

const graphJsonLd = supNode ? {
  '@context': 'https://schema.org',
  '@graph': [
    articleSchema({
      headline: 'What is an Inflatable SUP Board?',
      description: 'Complete guide to inflatable stand-up paddle boards: construction, technology, uses, and how they compare to hard boards.',
      datePublished: '2024-01-15',
      dateModified: '2026-06-01',
      author: 'Wavefella',
      publisher: 'Wavefella',
    }),
    {
      '@type': 'Product',
      name: supNode.name.en,
      description: supNode.description.en,
      brand: { '@type': 'Brand', name: 'Wavefella' },
      category: 'Water Sports Equipment',
    },
  ],
} : null;
---

<PageLayout>
  <script slot="before" is:inline type="application/ld+json" set:html={graphJsonLd ? JSON.stringify(graphJsonLd) : ''} />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Guide</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">What is an Inflatable SUP Board?</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">A complete guide to understanding inflatable stand-up paddle boards — construction, technology, and how to choose.</p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none">
      <h2>What is an Inflatable SUP?</h2>
      <p>An inflatable SUP (Stand-Up Paddle Board) is a portable watercraft made from drop-stitch PVC material that becomes rigid when inflated to high pressure (12-15 PSI). Unlike traditional hard boards made from foam and fiberglass, an inflatable SUP can be deflated, rolled up, and stored in a backpack-sized carrying case.</p>
      <p>Despite being inflatable, modern SUPs match the rigidity and performance of hard boards for most recreational and touring applications. The key innovation is <strong>drop-stitch construction</strong>: thousands of polyester threads connect the top and bottom fabric layers, preventing the board from ballooning when pressurized.</p>

      <h2>How It Works: Drop-Stitch Technology</h2>
      <p>The core of every inflatable SUP is the drop-stitch fabric. During manufacturing, thousands of threads are woven between two layers of PVC-coated fabric. When the board is inflated:</p>
      <ul>
        <li>The threads pull the top and bottom panels to a fixed distance apart</li>
        <li>This creates a rigid, flat platform that resists bending and flexing</li>
        <li>At 12-15 PSI, the board achieves stiffness comparable to EPS foam core boards</li>
      </ul>

      <h2>Key Components</h2>
      <ul>
        <li><strong>PVC Drop-Stitch Core</strong> — The primary structural layer providing rigidity</li>
        <li><strong>Rail Bands</strong> — Reinforced edges that protect against abrasion and impact</li>
        <li><strong>EVA Foam Deck Pad</strong> — Non-slip surface for standing comfort and traction</li>
        <li><strong>Fin System</strong> — Removable fins for directional stability (typically 2+1 configuration)</li>
        <li><strong>Valve</strong> — High-pressure one-way valve for inflation and deflation</li>
      </ul>

      <h2>Common Use Cases</h2>
      <ul>
        <li><strong>Flat Water Paddling</strong> — Lakes, calm bays, and slow-moving rivers</li>
        <li><strong>Touring</strong> — Long-distance paddling on open water requiring glide efficiency</li>
        <li><strong>Surfing</strong> — Small to medium waves (beginner to intermediate)</li>
        <li><strong>Fishing</strong> — Quiet, shallow-water access for anglers</li>
        <li><strong>Fitness</strong> — SUP yoga, pilates, and core training on water</li>
        <li><strong>Travel</strong> — Portable design makes it ideal for airlines and road trips</li>
      </ul>

      <h2>Inflatable vs Hard SUP: Key Differences</h2>
      <table>
        <tr><th>Aspect</th><th>Inflatable SUP</th><th>Hard SUP (EPS/Fiberglass)</th></tr>
        <tr><td>Portability</td><td>Packs into backpack</td><td>Requires roof rack or large vehicle</td></tr>
        <tr><td>Durability</td><td>Impact-resistant, no dings</td><td>Can crack, dent, or delaminate</td></tr>
        <tr><td>Storage</td><td>Fits in closet or car trunk</td><td>Needs dedicated storage space</td></tr>
        <tr><td>Performance</td><td>Excellent for recreational and touring</td><td>Superior for racing and advanced surfing</td></tr>
        <tr><td>Beginner Friendliness</td><td>Softer deck, less injury risk</td><td>Hard surface, less forgiving</td></tr>
        <tr><td>Setup Time</td><td>3-5 minutes inflation</td><td>Ready to go</td></tr>
      </table>

      <h2>How to Choose the Right SUP</h2>
      <p>When selecting an inflatable SUP, consider these factors:</p>
      <ul>
        <li><strong>Volume (liters)</strong> — Determines buoyancy. Higher volume supports more weight and provides stability.</li>
        <li><strong>Length</strong> — Longer boards (11-14 ft) track better for touring; shorter boards (9-10 ft) are more maneuverable for surfing.</li>
        <li><strong>Width</strong> — Wider boards (32-36 in) are more stable; narrower boards (28-31 in) are faster.</li>
        <li><strong>Thickness</strong> — 6-inch boards offer optimal rigidity; 4.7-inch boards are lighter and more portable.</li>
        <li><strong>Construction Quality</strong> — Look for fusion-laminated or woven drop-stitch for durability.</li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      <h3>Is an inflatable SUP as rigid as a hard board?</h3>
      <p>At proper inflation (12-15 PSI), modern drop-stitch SUPs achieve comparable rigidity for recreational paddling. Hard boards still offer an edge for racing and advanced surfing due to their lighter weight and more refined flex characteristics.</p>

      <h3>How long does it take to inflate?</h3>
      <p>With a dual-action pump, most boards reach 12-15 PSI in 3-5 minutes. Electric pumps are available and reduce inflation time to approximately 2 minutes.</p>

      <h3>Can I take an inflatable SUP on an airplane?</h3>
      <p>Yes. When deflated and rolled, most SUPs fit into a backpack that meets airline checked baggage requirements. Always check with your airline for size and weight limits.</p>

      <h3>How durable are inflatable SUPs?</h3>
      <p>Inflatable SUPs are highly durable. The military-grade PVC construction resists impacts, punctures, and UV damage. Minor punctures can be repaired in the field with the included repair kit.</p>

      <h3>What maintenance is required?</h3>
      <p>Rinse with fresh water after saltwater use. Store in a cool, dry place away from direct sunlight. Partially inflate during long-term storage to maintain shape without stressing seams.</p>
    </div>
  </section>
</PageLayout>
