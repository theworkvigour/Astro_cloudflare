---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import JsonLd from '~/components/common/JsonLd.astro';
import { contentV2Records, type ContentV2Record } from '~/data/content-v2';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;
const metadata = {
  title: `Content Library — ${SITE.name}`,
  description: 'Wavefella content library — guides, comparisons, problem solvers, and brand stories for water sports enthusiasts.',
};

const categories = [
  { key: 'problem', label: t('v2.category.problem'), desc: t('v2.category.problemDesc') },
  { key: 'guide', label: t('v2.category.guide'), desc: t('v2.category.guideDesc') },
  { key: 'comparison', label: t('v2.category.comparison'), desc: t('v2.category.comparisonDesc') },
  { key: 'product', label: t('v2.category.product'), desc: t('v2.category.productDesc') },
  { key: 'authority', label: t('v2.category.authority'), desc: t('v2.category.authorityDesc') },
] as const;

function groupBy<T>(items: T[], key: (item: T) => string): Record<string, T[]> {
  const map: Record<string, T[]> = {};
  for (const item of items) {
    const k = key(item);
    if (!map[k]) map[k] = [];
    map[k].push(item);
  }
  return map;
}

const grouped = groupBy(contentV2Records, c => c.category);
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="water-sports-content-library,surfing-guides,gear-comparisons,brand-story" />
  <JsonLd type="WebSite" data={{
    name: 'Wavefella Content Library',
    description: 'Guides, comparisons, and brand stories',
  }} />

  <section class="max-w-4xl mx-auto py-24 px-6" data-ai-block="definition">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{t('v2.index.label')}</span>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">{t('v2.index.title')}</h1>
    <p class="mt-4 text-lg text-gray-500">{t('v2.index.desc')}</p>
    <div class="mt-6 flex flex-wrap gap-2 text-xs">
      <span class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full font-medium">{t('v2.index.articles').replace('{count}', String(contentV2Records.length))}</span>
      <span class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full font-medium">{t('v2.index.categories').replace('{count}', String(categories.length))}</span>
    </div>
  </section>

  {categories.map(cat => {
    const entries = grouped[cat.key] || [];
    if (entries.length === 0) return null;
    return (
      <section class="max-w-4xl mx-auto pb-16 px-6">
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-gray-900">{cat.label}</h2>
          <p class="text-sm text-gray-500 mt-1">{cat.desc}</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {entries.map((c: ContentV2Record) => (
            <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
              <span class="text-xs font-medium text-sky-600 uppercase tracking-wide">{c.type.replace('-', ' ')}</span>
              <h3 class="mt-2 text-xl font-semibold text-gray-900">{c.title}</h3>
              <p class="mt-2 text-gray-500 text-sm">{c.description}</p>
              <div class="mt-3 flex items-center gap-2 text-xs">
                <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full capitalize">{c.difficulty}</span>
              </div>
              <a href={`/${lang}/v2/${c.slug}`} class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">{t('v2.index.read')}</a>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Layout>
