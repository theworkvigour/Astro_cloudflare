---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import JsonLd from '~/components/common/JsonLd.astro';
import Tldr from '~/components/common/Tldr.astro';
import { contentV2Records } from '~/data/content-v2';
import { guides } from '~/data/guides';
import { products } from '~/data/products';
import { languages } from '~/i18n/config';

export async function getStaticPaths() {
  const paths: Array<{
    params: { lang: string; slug: string };
    props: { entry: typeof contentV2Records[number] };
  }> = [];
  for (const lang of Object.keys(languages)) {
    for (const entry of contentV2Records) {
      paths.push({ params: { lang, slug: entry.slug }, props: { entry } });
    }
  }
  return paths;
}

const { entry } = Astro.props;
const { lang } = Astro.params;

function notNull<T>(x: T | null | undefined): x is T { return x != null; }

const resolvedGuides = entry.relatedGuides
  .map(slug => contentV2Records.find(c => c.slug === slug) || guides.find(g => g.slug === slug))
  .filter(notNull);

const resolvedProducts = entry.relatedProducts
  .map(id => products.find(p => p.id === id))
  .filter(notNull);

const isTierA = ['how-to-choose-a-surfboard-for-beginners', 'surfing-for-beginners', 'wetsuit-thickness-guide'].includes(entry.slug);

const metadata = {
  title: `Best ${entry.title.replace(/\(.*?\)/g, '').trim()} — ${SITE.name}`,
  description: entry.description,
};

const categoryLabels: Record<string, string> = {
  problem: 'Problem Solver',
  guide: 'Guide',
  comparison: 'Comparison',
  product: 'Product',
  authority: 'Brand Story',
};
---

<Layout metadata={metadata}>
  <JsonLd type="Article" article={{
    headline: entry.title,
    description: entry.description,
  }} data={{ url: `${SITE.site}/${lang}/v2/${entry.slug}` }} />

  <JsonLd type="FAQPage" faqs={entry.faq} />

  <article class="max-w-3xl mx-auto py-24 px-6">

    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href={`/${lang}/v2`} class="text-sky-600 hover:text-sky-700">Library</a>
      <span aria-hidden="true">/</span>
      <span class="px-2 py-0.5 bg-gray-100 rounded-full text-xs font-medium capitalize">{categoryLabels[entry.category] || entry.category}</span>
      {isTierA && <span class="px-2 py-0.5 bg-amber-50 text-amber-700 rounded-full text-xs font-medium">Most Read</span>}
    </div>

    <h1 class="text-4xl font-semibold text-gray-900 leading-tight">{entry.title}</h1>

    <Tldr summary={entry.tldr} className="mt-8" />

    <!-- AI Definition Block -->
    <section class="mt-8 p-6 bg-blue-50 border border-blue-100 rounded-2xl" data-ai-block="definition">
      <span class="text-xs font-semibold uppercase tracking-wider text-blue-600">TLDR</span>
      <p class="mt-2 text-gray-700 leading-relaxed">{entry.tldr}</p>
      <hr class="my-4 border-blue-100" />
      <span class="text-xs font-semibold uppercase tracking-wider text-blue-600">Definition</span>
      <p class="mt-2 text-gray-700 leading-relaxed">{entry.definition || entry.tldr}</p>
    </section>

    <section class="mt-12 space-y-16" data-ai-block="content">

      <section data-ai-block="problem">
        <h2 class="text-2xl font-semibold text-gray-900">The problem</h2>
        <p class="mt-3 text-gray-600 leading-relaxed">{entry.problem}</p>
      </section>

      <section data-ai-block="explanation">
        <h2 class="text-2xl font-semibold text-gray-900">How it works</h2>
        <p class="mt-3 text-gray-600 leading-relaxed">{entry.explanation}</p>
      </section>

      <section data-ai-block="solution">
        <h2 class="text-2xl font-semibold text-gray-900">The solution</h2>
        <p class="mt-3 text-gray-600 leading-relaxed">{entry.solution}</p>
      </section>

      <!-- Comparison -->
      <section data-ai-block="comparison">
        <h2 class="text-2xl font-semibold text-gray-900">Key comparisons</h2>
        <div class="mt-4 space-y-4">
          {entry.relatedGuides.length > 0 && (
            <div class="p-5 bg-white border border-gray-200 rounded-xl">
              <p class="text-sm font-semibold text-gray-900">Related guides</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {entry.relatedGuides.map(slug => {
                  const g = contentV2Records.find(c => c.slug === slug) || guides.find(gg => gg.slug === slug);
                  return g ? (
                    <a href={`/${lang}/v2/${g.slug}`} class="text-sm text-sky-600 hover:text-sky-700 underline underline-offset-2">{g.title}</a>
                  ) : null;
                })}
              </div>
            </div>
          )}
          {entry.relatedProducts.length > 0 && (
            <div class="p-5 bg-white border border-gray-200 rounded-xl">
              <p class="text-sm font-semibold text-gray-900">Shop related products</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {entry.relatedProducts.map(id => {
                  const p = products.find(pr => pr.id === id);
                  return p ? (
                    <a href={`/${lang}/products/${p.id}`} class="text-sm text-sky-600 hover:text-sky-700 underline underline-offset-2">{p.name}</a>
                  ) : null;
                })}
              </div>
            </div>
          )}
        </div>
      </section>

      <section data-ai-block="recommendation">
        <h2 class="text-2xl font-semibold text-gray-900">Our recommendation</h2>
        <div class="mt-4 p-6 bg-sky-50 border border-sky-100 rounded-2xl">
          <p class="text-gray-700 leading-relaxed">{entry.recommendation}</p>
        </div>
      </section>

    </section>

    {entry.faq.length > 0 && (
      <section class="mt-16" data-ai-block="faq">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">Frequently asked questions</h2>
        <div class="space-y-4" itemscope itemtype="https://schema.org/FAQPage">
          {entry.faq.map(item => (
            <details class="bg-white border border-gray-200 rounded-xl overflow-hidden group" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <summary class="px-6 py-4 font-semibold text-gray-900 cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
                <span itemprop="name">{item.q}</span>
                <span class="text-gray-400 group-open:rotate-180 transition-transform shrink-0">▼</span>
              </summary>
              <div class="px-6 pb-4" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                <p class="text-gray-600 leading-relaxed" itemprop="text">{item.a}</p>
              </div>
            </details>
          ))}
        </div>
      </section>
    )}

    {(resolvedGuides.length > 0 || resolvedProducts.length > 0) && (
      <section class="mt-16 p-8 bg-gray-50 rounded-2xl border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Keep reading</h2>
        <div class="flex flex-wrap gap-3">
          {resolvedGuides.map(g => (
            <a href={`/${lang}/v2/${g.slug}`}
               class="px-4 py-2 bg-white rounded-xl border border-gray-200 text-sm text-gray-700 hover:border-sky-300 hover:text-sky-700 transition-colors">
              {g.title} →
            </a>
          ))}
          {resolvedProducts.map(p => (
            <a href={`/${lang}/products/${p.id}`}
               class="px-4 py-2 bg-white rounded-xl border border-gray-200 text-sm font-medium text-gray-700 hover:border-sky-300 hover:text-sky-700 transition-colors">
              {p.name} →
            </a>
          ))}
        </div>
      </section>
    )}

  </article>
</Layout>
