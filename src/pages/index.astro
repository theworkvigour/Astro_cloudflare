---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { products } from '../data/products';

const metadata = {
  title: SITE.name,
  description: SITE?.description,
  ignoreTitleTemplate: true,
};

const heroImages = [
  '/images/wavefella/hero/hero-3.jpg',
  '/images/wavefella/hero/hero-4.jpg',
  '/images/wavefella/hero/hero-5.jpg',
  '/images/wavefella/hero/hero-scenic.png',
  '/images/wavefella/hero/hero-7.jpg',
];

const categoryMeta: Record<string, { img: string; color: string }> = {
  SUP:     { img: '/images/wavefella/categories/sup-touring.png', color: 'from-sky-400 to-blue-500' },
  KAYAK:   { img: '/images/wavefella/categories/kayak-river.jpg', color: 'from-teal-400 to-cyan-500' },
  DINGHY:  { img: '/images/wavefella/categories/dinghy.jpg', color: 'from-amber-400 to-orange-500' },
  RIB:     { img: '/images/wavefella/categories/rib.jpg', color: 'from-red-400 to-rose-500' },
  SAFETY:  { img: '/images/wavefella/categories/life-jacket.png', color: 'from-emerald-400 to-green-500' },
  ACCESSORY: { img: '/images/wavefella/categories/accessories.png', color: 'from-violet-400 to-purple-500' },
};

const categories = [...new Set(products.map(p => p.category))].map(cat => {
  const items = products.filter(p => p.category === cat);
    const waters = [...new Set(items.flatMap(p => p.environment))];
  const skills = [...new Set(items.map(p => p.skill))];
  const names: Record<string, string> = {
    SUP: 'SUP Boards', KAYAK: 'Inflatable Kayaks', DINGHY: 'Dinghies',
    RIB: 'RIBs & Rigid Hulls', SAFETY: 'Safety Equipment', ACCESSORY: 'Accessories',
  };
  const meta = categoryMeta[cat] || { img: '', color: 'from-gray-400 to-gray-500' };
  return {
    name: names[cat] || cat,
    count: items.length,
    waters: waters.slice(0, 3).join(', '),
    skill: skills.sort().join(' - '),
    img: meta.img,
    gradient: meta.color,
  };
});

const productVisuals: Record<string, string> = {
  'sup-explorer-11':    '/images/wavefella/products/sup-allround.jpg',
  'sup-tour-12':        '/images/wavefella/products/sup-touring.jpg',
  'kayak-lite':         '/images/wavefella/products/rk-river.jpg',
  'kayak-tandem':       '/images/wavefella/products/rk-expedition.jpg',
  'airdeck-270':        '/images/wavefella/products/airdeck-270.jpg',
  'airdeck-360':        '/images/wavefella/products/airdeck-360.jpg',
  'rib-330':            '/images/wavefella/products/rib-330.jpg',
  'rib-450-patrol':     '/images/wavefella/products/rib-450-patrol.jpg',
  'life-vest-classic':  '/images/wavefella/products/life-jacket.png',
  'life-vest-pro':      '/images/wavefella/products/life-jacket-2.jpg',
  'paddle-carbon':      '/images/wavefella/products/sup-paddle.jpg',
  'pump-dual':          '/images/wavefella/products/electric-pump.jpg',
};

const useCases = [
  {
    title: 'Beginner Water Sports',
    desc: 'Stable SUP boards and kayaks for first-time users.',
    scenario: 'A family visiting a lake for the weekend wants to try paddle boarding. They need stable, easy-to-launch equipment with clear safety guidance.',
    solution: 'The SUP Explorer 11 provides wide-body stability for beginners. The Life Vest Classic ensures CE-certified flotation. The Dual-Action Pump inflates both boards in under 10 minutes.',
    products: ['SUP Explorer 11', 'Life Vest Classic', 'Dual-Action Pump'],
    img: '/images/wavefella/use-cases/beginner.jpg',
  },
  {
    title: 'Outdoor Exploration',
    desc: 'Portable kayaks and dinghies for rivers, lakes, and coastal trips.',
    scenario: 'An outdoor enthusiast plans a week-long river trip and needs a boat that packs small, inflates at camp, and handles varying currents.',
    solution: 'The Kayak Lite packs into a backpack and inflates in under 4 minutes. Its drop-stitch construction handles lakes, slow rivers, and coastal paddling.',
    products: ['Inflatable Kayak Lite', 'Carbon Paddle', 'Life Vest Classic'],
    img: '/images/wavefella/use-cases/outdoor.jpg',
  },
  {
    title: 'Professional Operations',
    desc: 'Commercial-grade RIBs for tour operators and emergency response.',
    scenario: 'A coastal tour operator needs a fleet of durable boats that run daily trips in varying sea conditions and meet commercial safety regulations.',
    solution: 'The RIB 330 and RIB 450 Patrol use fiberglass deep-V hulls with Hypalon tubes for all-weather durability. Multiple units can be deployed with consistent performance.',
    products: ['RIB 330', 'RIB 450 Patrol', 'Life Vest Pro'],
    img: '/images/wavefella/use-cases/professional.jpg',
  },
  {
    title: 'Family Recreation',
    desc: 'Spacious dinghies for day trips, fishing, and watersports.',
    scenario: 'A family of four wants a stable boat for weekend lake outings, fishing trips, and towing a tube for the kids.',
    solution: 'The AirDeck 360 seats up to five with a reinforced air deck floor. It inflates at the launch site, stores in the car, and handles both calm lakes and sheltered coastal waters.',
    products: ['AirDeck 360', 'Life Vest Classic', 'Dual-Action Pump'],
    img: '/images/wavefella/use-cases/family.jpg',
  },
];

const trustPoints = [
  { title: 'ISO & CE Certified', desc: 'Every product meets international safety and quality standards.' },
  { title: 'Material Excellence', desc: 'Premium PVC and Hypalon fabrics tested for UV, abrasion, and temperature extremes.' },
  { title: 'Rigorous Testing', desc: 'Each vessel undergoes pressure, buoyancy, and load tests before shipment.' },
  { title: '2-Year Warranty', desc: 'All Wavefella products backed by comprehensive manufacturer warranty.' },
];

const proofPoints = [
  { metric: '12', label: 'products across 6 categories', detail: 'SUP, Kayak, Dinghy, RIB, Safety, Accessory' },
  { metric: '50+', label: 'countries served', detail: 'Global distribution network across EU, US, ASIA' },
  { metric: '2012', label: 'founded', detail: 'Over a decade of water sports manufacturing' },
  { metric: 'ISO', label: 'CE & ISO certified', detail: 'Every product meets international safety standards' },
];

const faqItems = [
  {
    q: 'What type of water sports equipment does Wavefella manufacture?',
    a: 'Wavefella manufactures inflatable SUP boards, kayaks, dinghies, rigid-hull inflatable boats (RIBs), life vests, and accessories. Our product line covers recreational, touring, commercial, and professional marine applications.',
  },
  {
    q: 'Are Wavefella products certified for safety?',
    a: 'Yes. All Wavefella safety equipment is CE certified and meets ISO 12402 standards. Our boats undergo pressure, buoyancy, and load testing before shipment. The Life Vest Pro is SOLAS compliant for offshore operations.',
  },
  {
    q: 'What skill levels do Wavefella products support?',
    a: 'We design for all skill levels: beginner (stable SUP boards and kayaks), intermediate (touring SUPs), advanced (high-performance RIBs), and professional (patrol and rescue vessels). Each product page specifies the recommended skill level.',
  },
  {
    q: 'Can Wavefella inflatable boats be used in saltwater?',
    a: 'Yes. Our inflatable boats use marine-grade PVC and Hypalon fabrics that resist UV, saltwater corrosion, and abrasion. We recommend rinsing with fresh water after saltwater use to extend product life.',
  },
  {
    q: 'What is the warranty on Wavefella products?',
    a: 'Wavefella offers a 2-year manufacturer warranty on all products covering manufacturing defects in materials and workmanship. The warranty does not cover damage from misuse, unauthorized modifications, or normal wear and tear.',
  },
  {
    q: 'How does the AI product recommendation work?',
    a: 'Our AI Product Selection Engine analyzes your question, matches it against our structured product catalog, and recommends the best product based on your skill level, water environment, and safety requirements. It does not generate marketing language or hallucinate products.',
  },
];
---

<Layout metadata={metadata}>
  <!-- Hero Carousel -->
  <section class="relative h-[80vh] min-h-[600px] flex items-center justify-center text-center text-white overflow-hidden" id="hero-carousel">
    <div class="absolute inset-0 bg-black/40 z-10"></div>
    {heroImages.map((src, i) => (
      <img
        src={src}
        alt="Wavefella water sports"
        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700"
        class:list={{ 'opacity-100': i === 0, 'opacity-0': i !== 0 }}
        data-carousel-slide={i}
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    ))}
    <div class="absolute bottom-8 z-20 flex gap-3">
      {heroImages.map((_, i) => (
        <button
          class="w-3 h-3 rounded-full border-2 border-white/60 transition-all"
          class:list={{ 'bg-white scale-125': i === 0, 'bg-transparent': i !== 0 }}
          data-carousel-dot={i}
          aria-label={`Slide ${i + 1}`}
        ></button>
      ))}
    </div>
    <div class="relative z-20 max-w-3xl mx-auto px-6">
      <span class="text-sm font-medium tracking-wide uppercase opacity-80">Since 2012</span>
      <h1 class="mt-6 text-5xl md:text-6xl font-bold tracking-tight drop-shadow-lg">
        Wavefella manufactures inflatable boats, SUPs, kayaks, RIBs, and safety equipment for recreational and professional water sports.
      </h1>
      <p class="mt-6 text-lg md:text-xl opacity-90 max-w-2xl mx-auto drop-shadow">
        SUP, kayak, dinghy, RIB, and safety equipment for outdoor adventure.
        Engineered for performance, built for safety.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="#products" class="px-8 py-4 bg-white text-gray-900 rounded-xl font-semibold hover:bg-gray-100 transition-colors shadow-lg">
          Explore products
        </a>
        <a href="#ask" class="px-8 py-4 border-2 border-white/60 text-white rounded-xl font-semibold hover:border-white transition-colors backdrop-blur-sm">
          Ask AI
        </a>
      </div>
    </div>
  </section>

  <!-- AI Summary -->
  <section class="max-w-6xl mx-auto py-24 px-6" id="ai-summary">
    <div class="bg-blue-50 border border-blue-100 rounded-2xl p-8 md:p-12">
      <span class="text-sm font-medium text-blue-600 tracking-wide uppercase">AI Summary</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">What is Wavefella?</h2>
      <p class="mt-6 text-lg text-gray-700 leading-relaxed">
        Wavefella is a water sports equipment manufacturer that designs and produces inflatable SUP boards, kayaks, dinghies, rigid-hull inflatable boats (RIBs), safety equipment, and accessories. Founded in 2012, the company serves recreational paddlers, commercial operators, marine professionals, and government agencies across 50+ countries. All products are CE certified and meet ISO safety standards.
      </p>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        <div>
          <h3 class="font-semibold text-gray-900">What we make</h3>
          <ul class="mt-2 text-sm text-gray-600 space-y-1">
            <li>Inflatable SUP boards for recreation and touring</li>
            <li>Inflatable kayaks for solo and tandem paddling</li>
            <li>Dinghies for day trips, fishing, and tender use</li>
            <li>RIBs for commercial, patrol, and rescue operations</li>
            <li>CE-certified life vests and marine accessories</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900">Who uses Wavefella</h3>
          <ul class="mt-2 text-sm text-gray-600 space-y-1">
            <li>Recreational paddlers and families</li>
            <li>Outdoor explorers and travelers</li>
            <li>Tour operators and commercial marine teams</li>
            <li>Law enforcement and search-and-rescue units</li>
            <li>Dive teams and offshore workers</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900">Key differentiators</h3>
          <ul class="mt-2 text-sm text-gray-600 space-y-1">
            <li>CE and ISO certified across all product lines</li>
            <li>Marine-grade PVC and Hypalon construction</li>
            <li>2-year manufacturer warranty</li>
            <li>AI-powered product selection engine</li>
            <li>12 products across 6 categories</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Product System -->
  <section id="products" class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Product System</span>
      <h2 class="mt-4 text-4xl font-semibold text-gray-900">{products.length} products across 6 categories</h2>
      <p class="mt-4 text-lg text-gray-500">From paddleboards to rescue vessels — each category designed for specific environments, skill levels, and use cases.
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {categories.map(cat => (
        <a href={"/products#" + cat.name.toLowerCase().replace(/\s+/g, '-')} class="group block rounded-2xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow bg-white">
          <div class={`h-48 bg-gradient-to-br ${cat.gradient} relative overflow-hidden`}>
            <img src={cat.img} alt={cat.name} class="w-full h-full object-cover opacity-70 group-hover:opacity-90 transition-opacity" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900">{cat.name}</h3>
            <p class="text-sm text-gray-400 mt-1">{cat.count} products</p>
            <div class="mt-3 flex flex-wrap gap-2 text-xs">
              <span class="px-2 py-1 bg-gray-100 rounded-full text-gray-600">{cat.waters}</span>
              <span class="px-2 py-1 bg-gray-100 rounded-full text-gray-600">{cat.skill}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Product Catalog -->
  <section class="bg-gray-50 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Product Catalog</span>
        <h2 class="mt-4 text-4xl font-semibold text-gray-900">Complete product lineup</h2>
        <p class="mt-4 text-lg text-gray-500">Every product with structured specs — skill level, water type, region, and safety requirements.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map(p => {
          const img = productVisuals[p.id] || '';
          return (
            <div class="bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-md transition-shadow">
              <div class="h-48 bg-gradient-to-br from-gray-100 to-gray-200 relative overflow-hidden">
                {img ? (
                  <>
                    <img src={img} alt={p.name} class="w-full h-full object-cover" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                  </>
                ) : (
                  <div class="flex items-center justify-center h-full text-gray-400 text-sm">{p.category}</div>
                )}
              </div>
              <div class="p-6">
                <h3 class="font-semibold text-gray-900 text-lg">{p.name}</h3>
                <p class="text-gray-500 mt-2 text-sm">{p.desc}</p>
                <div class="mt-4 flex flex-wrap gap-2 text-xs">
                  <span class="px-2 py-1 bg-sky-50 text-sky-700 rounded-full font-medium">{p.category}</span>
                  <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full">{p.skill}</span>
                  <span class="px-2 py-1 bg-gray-100 text-gray-500 rounded-full">{p.safety_level}</span>
                  {p.environment.slice(0, 2).map(e => (
                    <span class="px-2 py-1 bg-gray-100 text-gray-500 rounded-full">{e}</span>
                  ))}
                </div>
                {p.safety_rules.length > 0 && (
                  <p class="mt-3 text-xs text-amber-600 flex items-center gap-1">
                    <span>⚠</span> {p.safety_rules.join(', ')}
                  </p>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Use Cases</span>
      <h2 class="mt-4 text-4xl font-semibold text-gray-900">Built for real water experiences</h2>
      <p class="mt-4 text-lg text-gray-500">From first-time paddlers to professional operators — Wavefella equips every water adventure.</p>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      {useCases.map(u => (
        <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow">
          <div class="h-48 overflow-hidden">
            <img src={u.img} alt={u.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900">{u.title}</h3>
            <p class="text-gray-500 mt-2">{u.desc}</p>
            <div class="mt-4 p-4 bg-gray-50 rounded-xl">
              <p class="text-sm font-medium text-gray-700">Scenario</p>
              <p class="mt-1 text-sm text-gray-600">{u.scenario}</p>
            </div>
            <div class="mt-3 p-4 bg-sky-50 rounded-xl">
              <p class="text-sm font-medium text-sky-700">Solution</p>
              <p class="mt-1 text-sm text-gray-600">{u.solution}</p>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              {u.products.map(pr => (
                <span class="px-3 py-1 bg-gray-100 text-gray-700 text-xs rounded-full font-medium">{pr}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Proof Layer -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Results</span>
        <h2 class="mt-4 text-4xl font-semibold text-gray-900">Built to last, tested to perform</h2>
        <p class="mt-4 text-lg text-gray-500">Every Wavefella product undergoes rigorous testing and certification.</p>
      </div>
      <div class="grid md:grid-cols-4 gap-8 mb-16">
        {proofPoints.map(pt => (
          <div class="text-center">
            <div class="text-4xl font-bold text-sky-600">{pt.metric}</div>
            <div class="mt-2 text-lg font-semibold text-gray-900">{pt.label}</div>
            <div class="mt-1 text-sm text-gray-500">{pt.detail}</div>
          </div>
        ))}
      </div>
      <div class="grid md:grid-cols-4 gap-6">
        {trustPoints.map(t => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center mx-auto text-xl">✓</div>
            <h3 class="mt-4 font-semibold text-gray-900">{t.title}</h3>
            <p class="text-gray-500 mt-2 text-sm">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Ask -->
  <section id="ask" class="max-w-6xl mx-auto py-24 px-6 text-center">
    <div class="max-w-3xl mx-auto mb-12">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">AI Product Guide</span>
      <h2 class="mt-4 text-4xl font-semibold text-gray-900">Find the right product</h2>
      <p class="mt-4 text-lg text-gray-500">
        Ask our AI to compare products, recommend based on your skill level and water type,
        or check safety requirements.
      </p>
    </div>
    <div class="max-w-2xl mx-auto">
      <div class="flex gap-3">
        <input id="q" class="flex-1 px-5 py-4 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-400 text-lg" placeholder="Which SUP is good for a beginner on a lake?" />
        <button id="ask-btn" class="px-8 py-4 bg-gray-900 text-white rounded-xl font-semibold hover:bg-gray-800 transition-colors shrink-0">Ask</button>
      </div>
      <pre id="out" class="mt-8 text-left text-sm text-gray-700 bg-white border border-gray-200 rounded-2xl p-8 hidden whitespace-pre-wrap leading-relaxed"></pre>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-24 px-6" id="faq">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">FAQ</span>
        <h2 class="mt-4 text-4xl font-semibold text-gray-900">Frequently asked questions</h2>
      </div>
      <div class="space-y-4">
        {faqItems.map((item, i) => (
          <details class="bg-white border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="px-6 py-4 font-semibold text-gray-900 cursor-pointer hover:bg-gray-50 transition-colors list-none flex items-center justify-between">
              <span>{item.q}</span>
              <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="px-6 pb-4">
              <p class="text-gray-600 leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Wavefella",
    "url": "https://wavefella-en.theworkvigo.workers.dev",
    "description": "Water sports equipment manufacturer. Inflatable SUP boards, kayaks, dinghies, RIBs, safety equipment, and accessories.",
    "foundingDate": "2012",
    "areaServed": ["US", "EU", "ASIA", "GLOBAL"],
    "knowsAbout": ["Stand-up paddleboarding", "Kayaking", "Inflatable boats", "Water safety", "Marine equipment"],
    "brand": {
      "@type": "Brand",
      "name": "Wavefella",
      "brand": products.map(p => ({
        "@type": "Product",
        "name": p.name,
        "category": p.category,
        "description": p.desc,
        "audience": { "@type": "Audience", "suggestedGender": p.skill },
        "application": p.use_case,
        "safetyConsideration": p.safety_rules,
      }))
    },
    "mainEntity": {
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a,
        },
      }))
    }
  })} />

  <!-- Contact -->
  <section class="bg-gray-50 py-24 px-6" id="contact">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Get in touch</span>
        <h2 class="mt-4 text-4xl font-semibold text-gray-900">Contact Wavefella</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-8 border border-gray-200 text-center">
          <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center mx-auto text-sky-600 text-xl">📍</div>
          <h3 class="mt-4 font-semibold text-gray-900">Address</h3>
          <p class="mt-2 text-gray-500 text-sm">5067 Saddleback St<br />Montclair, CA 91763<br />USA</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-gray-200 text-center">
          <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center mx-auto text-sky-600 text-xl">📞</div>
          <h3 class="mt-4 font-semibold text-gray-900">Phone</h3>
          <p class="mt-2 text-gray-500 text-sm">213-557-7888</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-gray-200 text-center">
          <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center mx-auto text-sky-600 text-xl">✉</div>
          <h3 class="mt-4 font-semibold text-gray-900">Email</h3>
