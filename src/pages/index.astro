<script is:inline>
(function() {
  // Carousel
  var slides = document.querySelectorAll('[data-carousel-slide]');
  var dots = document.querySelectorAll('[data-carousel-dot]');
  if (slides.length > 1) {
    var current = 0;
    var interval = setInterval(next, 5000);
    function goTo(i) {
      if (i === current) return;
      slides[current].classList.remove('opacity-100');
      slides[current].classList.add('opacity-0');
      dots[current].classList.remove('bg-white', 'scale-125');
      dots[current].classList.add('bg-transparent');
      current = i;
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-100');
      dots[current].classList.remove('bg-transparent');
      dots[current].classList.add('bg-white', 'scale-125');
    }
    function next() { goTo((current + 1) % slides.length); }
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        clearInterval(interval);
        goTo(parseInt(this.getAttribute('data-carousel-dot')));
        interval = setInterval(next, 5000);
      });
    });
  }

  // AI Ask
  var btn = document.getElementById('ask-btn');
  var input = document.getElementById('q');
  var out = document.getElementById('out');
  if (!btn || !input || !out) return;

  btn.addEventListener('click', async function() {
    var q = input.value.trim();
    if (!q) return;
    out.classList.add('hidden');
    out.textContent = 'Thinking...';
    out.classList.remove('hidden');

    try {
      var res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: q }),
      });
      var data = await res.json();
      out.textContent = res.ok && data.answer ? data.answer : 'Error: ' + (data.error || 'Request failed');
    } catch (err) {
      out.textContent = 'Error: ' + err.message;
    }
  });
})();
</script>
