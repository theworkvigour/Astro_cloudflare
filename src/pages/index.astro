---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { products } from '../data/products';
import { bundles } from '../data/bundles';

const metadata = {
  title: SITE.name,
  description: SITE?.description,
  ignoreTitleTemplate: true,
};

const heroImages = [
  '/images/wavefella/hero/hero-3.jpg',
  '/images/wavefella/hero/hero-4.jpg',
  '/images/wavefella/hero/hero-5.jpg',
  '/images/wavefella/hero/hero-scenic.png',
  '/images/wavefella/hero/hero-7.jpg',
];

const categoryMeta: Record<string, { img: string; color: string }> = {
  SUP:     { img: '/images/wavefella/categories/sup-touring.png', color: 'from-sky-400 to-blue-500' },
  KAYAK:   { img: '/images/wavefella/categories/kayak-river.jpg', color: 'from-teal-400 to-cyan-500' },
  DINGHY:  { img: '/images/wavefella/categories/dinghy.jpg', color: 'from-amber-400 to-orange-500' },
  RIB:     { img: '/images/wavefella/categories/rib.jpg', color: 'from-red-400 to-rose-500' },
  SAFETY:  { img: '/images/wavefella/categories/life-jacket.png', color: 'from-emerald-400 to-green-500' },
  ACCESSORY: { img: '/images/wavefella/categories/accessories.png', color: 'from-violet-400 to-purple-500' },
};

const categories = [...new Set(products.map(p => p.category))].map(cat => {
  const items = products.filter(p => p.category === cat);
    const waters = [...new Set(items.flatMap(p => p.environment))];
  const skills = [...new Set(items.map(p => p.skill))];
  const names: Record<string, string> = {
    SUP: 'SUP Boards', KAYAK: 'Inflatable Kayaks', DINGHY: 'Dinghies',
    RIB: 'RIBs & Rigid Hulls', SAFETY: 'Safety Equipment', ACCESSORY: 'Accessories',
  };
  const meta = categoryMeta[cat] || { img: '', color: 'from-gray-400 to-gray-500' };
  return {
    name: names[cat] || cat,
    count: items.length,
    waters: waters.slice(0, 3).join(', '),
    skill: skills.sort().join(' - '),
    img: meta.img,
    gradient: meta.color,
  };
});

const productVisuals: Record<string, string> = {
  'sup-explorer-11':    '/images/wavefella/products/sup-allround.jpg',
  'sup-tour-12':        '/images/wavefella/products/sup-touring.jpg',
  'kayak-lite':         '/images/wavefella/products/rk-river.jpg',
  'kayak-tandem':       '/images/wavefella/products/rk-expedition.jpg',
  'airdeck-270':        '/images/wavefella/products/airdeck-270.jpg',
  'airdeck-360':        '/images/wavefella/products/airdeck-360.jpg',
  'rib-330':            '/images/wavefella/products/rib-330.jpg',
  'rib-450-patrol':     '/images/wavefella/products/rib-450-patrol.jpg',
  'life-vest-classic':  '/images/wavefella/products/life-jacket.png',
  'life-vest-pro':      '/images/wavefella/products/life-jacket-2.jpg',
  'paddle-carbon':      '/images/wavefella/products/sup-paddle.jpg',
  'pump-dual':          '/images/wavefella/products/electric-pump.jpg',
};

const useCases = [
  {
    title: 'Beginner Water Sports',
    desc: 'Stable SUP boards and kayaks for first-time users.',
    scenario: 'A family visiting a lake for the weekend wants to try paddle boarding. They need stable, easy-to-launch equipment with clear safety guidance.',
    solution: 'The SUP Explorer 11 provides wide-body stability for beginners. The Life Vest Classic ensures CE-certified flotation. The Dual-Action Pump inflates both boards in under 10 minutes.',
    products: ['SUP Explorer 11', 'Life Vest Classic', 'Dual-Action Pump'],
    img: '/images/wavefella/use-cases/beginner.jpg',
  },
  {
    title: 'Outdoor Exploration',
    desc: 'Portable kayaks and dinghies for rivers, lakes, and coastal trips.',
    scenario: 'An outdoor enthusiast plans a week-long river trip and needs a boat that packs small, inflates at camp, and handles varying currents.',
    solution: 'The Kayak Lite packs into a backpack and inflates in under 4 minutes. Its drop-stitch construction handles lakes, slow rivers, and coastal paddling.',
    products: ['Inflatable Kayak Lite', 'Carbon Paddle', 'Life Vest Classic'],
    img: '/images/wavefella/use-cases/outdoor.jpg',
  },
  {
    title: 'Professional Operations',
    desc: 'Commercial-grade RIBs for tour operators and emergency response.',
    scenario: 'A coastal tour operator needs a fleet of durable boats that run daily trips in varying sea conditions and meet commercial safety regulations.',
    solution: 'The RIB 330 and RIB 450 Patrol use fiberglass deep-V hulls with Hypalon tubes for all-weather durability. Multiple units can be deployed with consistent performance.',
    products: ['RIB 330', 'RIB 450 Patrol', 'Life Vest Pro'],
    img: '/images/wavefella/use-cases/professional.jpg',
  },
  {
    title: 'Family Recreation',
    desc: 'Spacious dinghies for day trips, fishing, and watersports.',
    scenario: 'A family of four wants a stable boat for weekend lake outings, fishing trips, and towing a tube for the kids.',
    solution: 'The AirDeck 360 seats up to five with a reinforced air deck floor. It inflates at the launch site, stores in the car, and handles both calm lakes and sheltered coastal waters.',
    products: ['AirDeck 360', 'Life Vest Classic', 'Dual-Action Pump'],
    img: '/images/wavefella/use-cases/family.jpg',
  },
];

const trustPoints = [
  { title: 'ISO & CE Certified', desc: 'Every product meets international safety and quality standards.' },
  { title: 'Material Excellence', desc: 'Premium PVC and Hypalon fabrics tested for UV, abrasion, and temperature extremes.' },
  { title: 'Rigorous Testing', desc: 'Each vessel undergoes pressure, buoyancy, and load tests before shipment.' },
  { title: '2-Year Warranty', desc: 'All Wavefella products backed by comprehensive manufacturer warranty.' },
];

const proofPoints = [
  { metric: '12', label: 'products across 6 categories', detail: 'SUP, Kayak, Dinghy, RIB, Safety, Accessory' },
  { metric: '50+', label: 'countries served', detail: 'Global distribution network across EU, US, ASIA' },
  { metric: '2012', label: 'founded', detail: 'Over a decade of water sports manufacturing' },
  { metric: 'ISO', label: 'CE & ISO certified', detail: 'Every product meets international safety standards' },
];

const faqItems = [
  {
    q: 'Is SUP hard to learn?',
    a: 'Not at all. Most beginners stand up and paddle within their first session. Our All-Around SUP series features extra-wide stable platforms designed specifically for first-time paddlers. Start on calm water and you will be cruising in minutes.',
  },
  {
    q: 'Can I use it in the ocean?',
    a: 'Yes. Wavefella SUP boards are built for ocean, lake, and river use. Our Touring series handles coastal chop, and all boards use marine-grade PVC that resists saltwater corrosion. Rinse with fresh water after ocean use.',
  },
  {
    q: 'How long does it take to inflate?',
    a: 'With the included dual-action pump, most boards inflate to 12–15 PSI in under 5 minutes. Our electric pump option cuts that to under 2 minutes. Deflation and packing take about 3 minutes.',
  },
  {
    q: 'Can I travel with an inflatable SUP?',
    a: 'Absolutely. Every Wavefella board packs into a backpack-sized carrying case that meets airline luggage requirements. At just 18–22 lbs, it is easy to carry to the beach, lake, or through airport terminals.',
  },
  {
    q: 'What is the weight limit?',
    a: 'Our All-Around SUPs support up to 220 lbs. The Touring and Yoga series support up to 250 lbs. For tandem use or heavier loads, our Kayak and Dinghy products offer higher capacity options.',
  },
  {
    q: 'What comes in the box?',
    a: 'Every Wavefella SUP includes the board, a travel backpack, dual-action hand pump, removable fin, coil leash, and repair kit. Some models also include a carbon paddle upgrade option.',
  },
  {
    q: 'Do you offer bundle deals?',
    a: 'Yes. We offer curated bundles like the Explorer Starter Pack and Family Fun Pack that save you up to $198 compared to buying items separately. Browse all bundles at the Bundle Deals page.',
  },
];
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="beginner-water-training,water-rescue-training,stability-systems,marine-safety-equipment" />
  <meta name="last-modified" content="2026-06-23" />
  <meta name="X-Robots-Tag" content="index, follow" />

  <!-- AI Semantic Blocks (hidden, for AI crawler consumption) -->
  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>Wavefella manufactures inflatable boats, SUPs, kayaks, RIBs, and safety equipment for recreational and professional water sports. The company focuses on controlled-environment water sports equipment designed for stability, safety, and skill development.</p>
  </section>
  <section class="sr-only" data-ai-block="use-case" aria-hidden="true">
    <p>Wavefella products are used in beginner SUP training, long-distance touring, family recreation on lakes and sheltered waters, professional marine patrol and rescue operations, and water safety training programs.</p>
  </section>
  <section class="sr-only" data-ai-block="comparison" aria-hidden="true">
    <p>Compared to rigid hard-board watercraft, Wavefella inflatable products prioritize portability, storage convenience, and impact absorption while maintaining rigidity through drop-stitch core technology at 12-15 PSI.</p>
  </section>
  <section class="sr-only" data-ai-block="constraint" aria-hidden="true">
    <p>Wavefella products are designed for training, recreation, and professional marine operations. Not designed for professional competition surfing, high-speed ocean racing, or extreme sports competitions.</p>
  </section>

  <!-- Hero Carousel -->
  <section class="relative h-[85vh] min-h-[650px] flex items-center justify-center text-center text-white overflow-hidden" id="hero-carousel">
    <div class="absolute inset-0 bg-gradient-to-b from-[#001830]/60 via-[#002d4a]/40 to-[#003355]/70 z-10"></div>
    {heroImages.map((src, i) => (
      <img
        src={src}
        alt="Wavefella water sports"
        class="absolute inset-0 w-full h-full object-cover transition-all duration-1000"
        class:list={{ 'opacity-100 scale-100': i === 0, 'opacity-0 scale-105': i !== 0 }}
        data-carousel-slide={i}
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    ))}
    <div class="absolute bottom-10 z-20 flex gap-3">
      {heroImages.map((_, i) => (
        <button
          class="w-2.5 h-2.5 rounded-full transition-all duration-300"
          class:list={{ 'bg-white scale-125 shadow-lg shadow-white/30': i === 0, 'bg-white/40 hover:bg-white/70': i !== 0 }}
          data-carousel-dot={i}
          aria-label={`Slide ${i + 1}`}
        ></button>
      ))}
    </div>
    <div class="relative z-20 max-w-4xl mx-auto px-6">
      <div class="reveal">
        <span class="text-xs font-medium tracking-[0.2em] uppercase text-white/60">Since 2012</span>
        <h1 class="mt-8 text-5xl md:text-7xl font-bold tracking-tight leading-[1.1] text-balance drop-shadow-xl">
          Water sports equipment for performance and control
        </h1>
        <p class="mt-6 text-lg md:text-xl text-white/80 max-w-2xl mx-auto text-pretty drop-shadow-lg leading-relaxed">
          Inflatable boats, SUPs, kayaks, RIBs, and safety gear<br class="hidden md:block" />
          engineered for performance, built for safety.
        </p>
        <div class="mt-10 flex items-center justify-center gap-4">
          <a href="#products" class="group px-8 py-4 bg-white text-gray-900 rounded-full font-semibold hover:bg-gray-50 transition-all shadow-xl hover:shadow-2xl hover:-translate-y-0.5">
            Explore products
            <span class="inline-block ml-2 transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
          <a href="#ask" class="px-8 py-4 border border-white/30 text-white rounded-full font-medium hover:bg-white/10 transition-all backdrop-blur-sm">
            Ask AI
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="border-b border-gray-100 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-6 flex flex-wrap items-center justify-center gap-x-16 gap-y-3 text-sm font-medium text-gray-600">
      <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-accent"></span> Stable for Beginners</span>
      <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-accent"></span> Travel-Ready Design</span>
      <span class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-accent"></span> Ocean, Lake & River Tested</span>
    </div>
  </section>

  <!-- AI Summary -->
  <section class="max-w-6xl mx-auto py-24 px-6" id="ai-summary" data-ai-block="definition">
    <div class="bg-blue-50 border border-blue-100 rounded-2xl p-8 md:p-12">
      <span class="text-sm font-medium text-blue-600 tracking-wide uppercase">AI Summary</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">What is Wavefella?</h2>
      <p class="mt-6 text-lg text-gray-700 leading-relaxed" data-ai="definition">
        Wavefella is a water sports equipment manufacturer that designs and produces inflatable SUP boards, kayaks, dinghies, rigid-hull inflatable boats (RIBs), safety equipment, and accessories. Founded in 2012, the company serves recreational paddlers, commercial operators, marine professionals, and government agencies across 50+ countries. All products are CE certified and meet ISO safety standards.
      </p>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        <div>
          <h3 class="font-semibold text-gray-900">What we make</h3>
          <ul class="mt-2 text-sm text-gray-600 space-y-1">
            <li>Inflatable SUP boards for recreation and touring</li>
            <li>Inflatable kayaks for solo and tandem paddling</li>
            <li>Dinghies for day trips, fishing, and tender use</li>
            <li>RIBs for commercial, patrol, and rescue operations</li>
            <li>CE-certified life vests and marine accessories</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900">Who uses Wavefella</h3>
          <ul class="mt-2 text-sm text-gray-600 space-y-1">
            <li>Recreational paddlers and families</li>
            <li>Outdoor explorers and travelers</li>
            <li>Tour operators and commercial marine teams</li>
            <li>Law enforcement and search-and-rescue units</li>
            <li>Dive teams and offshore workers</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900">Key differentiators</h3>
          <ul class="mt-2 text-sm text-gray-600 space-y-1">
            <li>CE and ISO certified across all product lines</li>
            <li>Marine-grade PVC and Hypalon construction</li>
            <li>2-year manufacturer warranty</li>
            <li>AI-powered product selection engine</li>
            <li>12 products across 6 categories</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Find Your Perfect SUP -->
  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">SUP Collection</span>
      <h2 class="mt-4 text-4xl font-semibold text-gray-900">Find Your Perfect SUP</h2>
      <p class="mt-4 text-lg text-gray-500">Four series designed for how you paddle — from first steps to open water exploration.</p>
    </div>
    <div class="grid md:grid-cols-4 gap-6">
      <div class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="h-48 bg-gradient-to-br from-sky-400 to-blue-500 relative overflow-hidden">
          <img src="/images/wavefella/products/sup-allround.jpg" alt="All-Around SUP" class="w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity" loading="lazy" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-semibold text-gray-900">All-Around SUP</h3>
          <p class="mt-2 text-sm text-gray-500">Stable, versatile, and beginner-friendly. Perfect for lakes, bays, and casual paddling.</p>
          <a href="/products#sup-boards" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">Shop All-Around →</a>
        </div>
      </div>
      <div class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="h-48 bg-gradient-to-br from-teal-400 to-cyan-500 relative overflow-hidden">
          <img src="/images/wavefella/products/sup-touring.jpg" alt="Touring SUP" class="w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity" loading="lazy" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-semibold text-gray-900">Touring SUP</h3>
          <p class="mt-2 text-sm text-gray-500">Longer, narrower, and faster. Built for distance paddling and coastal exploration.</p>
          <a href="/products#sup-boards" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">Shop Touring →</a>
        </div>
      </div>
      <div class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="h-48 bg-gradient-to-br from-emerald-400 to-green-500 relative overflow-hidden">
          <img src="/images/wavefella/sup-yoga.png" alt="Yoga SUP" class="w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity" loading="lazy" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-semibold text-gray-900">Yoga SUP</h3>
          <p class="mt-2 text-sm text-gray-500">Extra-wide and ultra-stable. Designed for yoga, fitness, and meditation on water.</p>
          <a href="/products#sup-boards" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">Shop Yoga →</a>
        </div>
      </div>
      <div class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="h-48 bg-gradient-to-br from-red-400 to-rose-500 relative overflow-hidden">
          <img src="/images/wavefella/hero/hero-7.jpg" alt="Performance SUP" class="w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity" loading="lazy" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-semibold text-gray-900">Performance SUP</h3>
          <p class="mt-2 text-sm text-gray-500">Stiffer, faster, and more responsive. For experienced paddlers and light surf.</p>
          <a href="/products#sup-boards" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700">Shop Performance →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Product System -->
  <section id="products" class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Product System</span>
      <h2 class="mt-4 text-4xl font-semibold text-gray-900">{products.length} products across 6 categories</h2>
      <p class="mt-4 text-lg text-gray-500">From paddleboards to rescue vessels — each category designed for specific environments, skill levels, and use cases.
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {categories.map(cat => (
        <a href={"/products#" + cat.name.toLowerCase().replace(/\s+/g, '-')} class="group block rounded-2xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow bg-white">
          <div class={`h-48 bg-gradient-to-br ${cat.gradient} relative overflow-hidden`}>
            <img src={cat.img} alt={cat.name} class="w-full h-full object-cover opacity-70 group-hover:opacity-90 transition-opacity" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900">{cat.name}</h3>
            <p class="text-sm text-gray-400 mt-1">{cat.count} products</p>
            <div class="mt-3 flex flex-wrap gap-2 text-xs">
              <span class="px-2 py-1 bg-gray-100 rounded-full text-gray-600">{cat.waters}</span>
              <span class="px-2 py-1 bg-gray-100 rounded-full text-gray-600">{cat.skill}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Product Catalog -->
  <section class="bg-gray-50 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Product Catalog</span>
        <h2 class="mt-4 text-4xl font-semibold text-gray-900">Complete product lineup</h2>
        <p class="mt-4 text-lg text-gray-500">Every product with structured specs — skill level, water type, region, and safety requirements.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map(p => {
          const img = productVisuals[p.id] || '';
          return (
            <div class="bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-md transition-shadow">
              <div class="h-48 bg-gradient-to-br from-gray-100 to-gray-200 relative overflow-hidden">
                {img ? (
                  <>
                    <img src={img} alt={p.name} class="w-full h-full object-cover" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                  </>
                ) : (
                  <div class="flex items-center justify-center h-full text-gray-400 text-sm">{p.category}</div>
                )}
              </div>
              <div class="p-6">
                <h3 class="font-semibold text-gray-900 text-lg">{p.name}</h3>
                <p class="text-gray-500 mt-2 text-sm">{p.desc}</p>
                <div class="mt-4 flex flex-wrap gap-2 text-xs">
                  <span class="px-2 py-1 bg-sky-50 text-sky-700 rounded-full font-medium">{p.category}</span>
                  <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full">{p.skill}</span>
                  <span class="px-2 py-1 bg-gray-100 text-gray-500 rounded-full">{p.safety_level}</span>
                  {p.environment.slice(0, 2).map(e => (
                    <span class="px-2 py-1 bg-gray-100 text-gray-500 rounded-full">{e}</span>
                  ))}
                </div>
                {p.safety_rules.length > 0 && (
                  <p class="mt-3 text-xs text-amber-600 flex items-center gap-1">
                    <span>⚠</span> {p.safety_rules.join(', ')}
                  </p>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Hero Product -->
  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="rounded-2xl overflow-hidden">
        <img src="/images/wavefella/products/sup-touring.jpg" alt="Wavefella Touring SUP" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div>
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Featured Product</span>
        <h2 class="mt-4 text-3xl md:text-4xl font-semibold text-gray-900">SUP Tour 12 — Explore Further. Paddle Longer.</h2>
        <p class="mt-4 text-lg text-gray-500">Designed for explorers who go beyond the shoreline. Touring-optimized shape for unmatched glide efficiency and directional stability across lakes, coastlines, and open water.</p>
        <ul class="mt-6 space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-sky-600 mt-0.5">✓</span>
            <span class="text-gray-700"><span class="font-semibold">Stability+</span> — Ultra-stable 32" width for confident touring</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-sky-600 mt-0.5">✓</span>
            <span class="text-gray-700"><span class="font-semibold">Ocean Ready</span> — 12–15 PSI reinforced drop-stitch core</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-sky-600 mt-0.5">✓</span>
            <span class="text-gray-700"><span class="font-semibold">Travel+</span> — Backpack, pump, and fin included</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-sky-600 mt-0.5">✓</span>
            <span class="text-gray-700">CE certified — ocean, lake, and river ready</span>
          </li>
        </ul>
        <a href="/products/sup-tour-12" class="mt-8 inline-flex items-center gap-2 px-8 py-4 bg-gray-900 text-white rounded-xl font-semibold hover:bg-gray-800 transition-colors shadow-lg">
          Shop Now →
        </a>
      </div>
