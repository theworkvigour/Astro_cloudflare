---
import Layout from '~/layouts/PageLayout.astro';
import { ui } from '~/styles/ui';
import { SITE } from 'astrowind:config';

const metadata = {
  title: SITE.name,
  description: SITE?.description,
  ignoreTitleTemplate: true,
};

const productSystem = [
  {
    name: 'SUP Boards',
    desc: 'Stable inflatable paddle boards for lakes, sea, and beginners. Lightweight, portable, and easy to store.',
    use: 'Recreation / Training / Exploration',
  },
  {
    name: 'Inflatable Kayaks',
    desc: 'Lightweight portable kayaks for rivers and coastal waters. Designed for touring, fishing, and adventure.',
    use: 'Touring / Fishing / Adventure',
  },
  {
    name: 'RIBs & Dinghies',
    desc: 'Rigid-hull inflatable boats and portable dinghies for transport, commercial use, and rescue operations.',
    use: 'Transport / Commercial / Rescue',
  },
  {
    name: 'Safety Equipment',
    desc: 'Certified life vests, PFDs, and protection gear for all water activities. Safety first, always.',
    use: 'All water activities',
  },
  {
    name: 'Accessories',
    desc: 'Paddles, pumps, bags, and essential gear for maintenance, transport, and customization.',
    use: 'Maintenance / Transport / Customization',
  },
];

const useCases = [
  {
    title: 'Beginner Water Sports',
    desc: 'Stable SUP boards and kayaks designed for first-time users. Easy launch, stable ride, confidence building.',
  },
  {
    title: 'Outdoor Exploration',
    desc: 'Portable kayaks and dinghies for rivers, lakes, and coastal trips. Packable and ready for adventure.',
  },
  {
    title: 'Professional Operations',
    desc: 'Commercial-grade RIBs for tour operators, ferry services, law enforcement, and emergency response.',
  },
  {
    title: 'Family Recreation',
    desc: 'Spacious dinghies and safe equipment for family day trips, fishing, and watersports.',
  },
];

const trustPoints = [
  { title: 'ISO & CE Certified', desc: 'Every product meets international safety and quality standards.' },
  { title: 'Material Excellence', desc: 'Premium PVC and Hypalon fabrics tested for UV, abrasion, and temperature extremes.' },
  { title: 'Rigorous Testing', desc: 'Each vessel undergoes pressure, buoyancy, and load tests before shipment.' },
  { title: '2-Year Warranty', desc: 'All Wavefella products backed by comprehensive manufacturer warranty.' },
];
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="py-28 text-center bg-gradient-to-b from-sky-50 to-white">
    <div class="max-w-3xl mx-auto px-6">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Since 2012</span>
      <h1 class="mt-6 text-5xl font-semibold tracking-tight text-gray-900">
        Explore Water. Build Freedom.
      </h1>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
        Wavefella designs professional water sports equipment for paddling, exploration,
        and outdoor adventure. Every product is engineered for performance, durability, and safety.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="#products" class="px-6 py-3 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors">
          Explore products
        </a>
        <a href="#ask" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-xl font-medium hover:border-gray-400 transition-colors">
          Ask AI
        </a>
      </div>
    </div>
  </section>

  <!-- Product System -->
  <section id="products" class="max-w-6xl mx-auto py-20 px-6">
    <div class="max-w-3xl">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Product System</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">Complete water sports equipment line</h2>
      <p class="mt-4 text-gray-500">
        From paddleboards to rescue vessels, every category is designed with a clear purpose and use case.
      </p>
    </div>
    <div class="mt-12 grid md:grid-cols-3 gap-6">
      {productSystem.map(p => (
        <div class="border border-gray-200 rounded-2xl p-6 hover:border-gray-300 transition-colors">
          <h3 class="text-xl font-semibold text-gray-900">{p.name}</h3>
          <p class="text-gray-500 mt-2">{p.desc}</p>
          <p class="text-sm text-gray-400 mt-4">Use: {p.use}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Use Cases -->
  <section class="bg-gray-50 py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Use Cases</span>
        <h2 class="mt-4 text-3xl font-semibold text-gray-900">Built for real water experiences</h2>
        <p class="mt-4 text-gray-500">
          Whether you are a beginner or a professional, Wavefella has the right equipment for your水上活动。
        </p>
      </div>
      <div class="mt-12 grid md:grid-cols-4 gap-6">
        {useCases.map(u => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6">
            <h3 class="font-semibold text-gray-900">{u.title}</h3>
            <p class="text-gray-500 mt-2 text-sm">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Layer -->
  <section class="max-w-6xl mx-auto py-20 px-6">
    <div class="max-w-3xl">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Safety & Quality</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">Built to last, tested to perform</h2>
      <p class="mt-4 text-gray-500">
        Every Wavefella product undergoes rigorous testing and certification to meet international standards.
      </p>
    </div>
    <div class="mt-12 grid md:grid-cols-4 gap-6">
      {trustPoints.map(t => (
        <div class="border border-gray-200 rounded-2xl p-6">
          <h3 class="font-semibold text-gray-900">{t.title}</h3>
          <p class="text-gray-500 mt-2 text-sm">{t.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- AI Ask -->
  <section id="ask" class="bg-gray-50 py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">AI Product Guide</span>
        <h2 class="mt-4 text-3xl font-semibold text-gray-900">Ask about our products</h2>
        <p class="mt-4 text-gray-500">
          Not sure which product fits your needs? Ask our AI guide for product comparisons,
          use case recommendations, and safety advice. Neutral, factual, no sales pitch.
        </p>
      </div>
      <div class="mt-10 max-w-2xl mx-auto">
        <form id="ask-form" class="flex gap-3">
          <input
            id="ask-input"
            type="text"
            placeholder="E.g. What is the difference between a SUP and a kayak?"
            class="flex-1 px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-400"
            autocomplete="off"
          />
          <button type="submit" class="px-6 py-3 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors shrink-0">
            Ask
          </button>
        </form>
        <div id="ask-output" class="mt-8 hidden">
          <div id="ask-answer" class="p-6 bg-white border border-gray-200 rounded-2xl text-gray-700 leading-relaxed"></div>
          <div id="ask-sources" class="mt-3 text-xs text-gray-400"></div>
        </div>
        <div id="ask-error" class="mt-4 text-sm text-red-500 hidden"></div>
      </div>
    </div>
  </section>

  <!-- Contact / Distribution -->
  <section class="py-20 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Get in touch</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">Contact & Distribution</h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        For distributors, retail partners, or product inquiries. We welcome collaboration
        with dealers, rental operators, and water sports professionals worldwide.
      </p>
      <a href="/contact" class="mt-8 inline-block px-6 py-3 border border-gray-300 text-gray-700 rounded-xl font-medium hover:border-gray-400 transition-colors">
        Get in touch
      </a>
    </div>
  </section>
</Layout>

<script is:inline>
(function() {
  var form = document.getElementById('ask-form');
  var input = document.getElementById('ask-input');
  var output = document.getElementById('ask-output');
  var answer = document.getElementById('ask-answer');
  var sources = document.getElementById('ask-sources');
  var error = document.getElementById('ask-error');

  if (!form || !input || !output || !answer || !sources || !error) return;

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var q = input.value.trim();
    if (!q) return;

    output.classList.add('hidden');
    error.classList.add('hidden');
    answer.textContent = 'Thinking...';
    output.classList.remove('hidden');
    sources.textContent = '';

    try {
      var res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: q }),
      });
      var data = await res.json();

      if (res.ok && data.answer) {
        answer.textContent = data.answer;
        if (data.sources && data.sources.length > 0) {
          sources.textContent = 'Sources: ' + data.sources.map(function(s) { return s.title; }).join(', ');
        }
      } else {
        throw new Error(data.error || 'Request failed');
      }
    } catch (err) {
      output.classList.add('hidden');
      error.textContent = 'Error: ' + err.message;
      error.classList.remove('hidden');
    }
  });
})();
</script>
