---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { products } from '../data/products';

const metadata = {
  title: SITE.name,
  description: SITE?.description,
  ignoreTitleTemplate: true,
};

const categories = [...new Set(products.map(p => p.category))].map(cat => {
  const items = products.filter(p => p.category === cat);
  const waters = [...new Set(items.flatMap(p => p.water))];
  const skills = [...new Set(items.map(p => p.skill))];
  const names: Record<string, string> = {
    SUP: 'SUP Boards', KAYAK: 'Inflatable Kayaks', DINGHY: 'Dinghies',
    RIB: 'RIBs & Rigid Hulls', SAFETY: 'Safety Equipment', ACCESSORY: 'Accessories',
  };
  return {
    name: names[cat] || cat,
    count: items.length,
    waters: waters.slice(0, 3).join(', '),
    skill: skills.sort().join(' - '),
  };
});

const useCases = [
  { title: 'Beginner Water Sports', desc: 'Stable SUP boards and kayaks for first-time users. Confidence building on calm water.' },
  { title: 'Outdoor Exploration', desc: 'Portable kayaks and dinghies for rivers, lakes, and coastal trips. Packable adventure.' },
  { title: 'Professional Operations', desc: 'Commercial-grade RIBs for tour operators, law enforcement, and emergency response.' },
  { title: 'Family Recreation', desc: 'Spacious dinghies and safe equipment for family day trips, fishing, and watersports.' },
];

const trustPoints = [
  { title: 'ISO & CE Certified', desc: 'Every product meets international safety and quality standards.' },
  { title: 'Material Excellence', desc: 'Premium PVC and Hypalon fabrics tested for UV, abrasion, and temperature extremes.' },
  { title: 'Rigorous Testing', desc: 'Each vessel undergoes pressure, buoyancy, and load tests before shipment.' },
  { title: '2-Year Warranty', desc: 'All Wavefella products backed by comprehensive manufacturer warranty.' },
];
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="py-28 text-center bg-gradient-to-b from-sky-50 to-white">
    <div class="max-w-3xl mx-auto px-6">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Since 2012</span>
      <h1 class="mt-6 text-5xl font-semibold tracking-tight text-gray-900">
        Wavefella — Global Water Sports Brand
      </h1>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
        SUP, kayak, dinghy, RIB, and safety equipment for outdoor adventure.
        Engineered for performance, built for safety.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="#products" class="px-6 py-3 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors">
          Explore products
        </a>
        <a href="#ask" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-xl font-medium hover:border-gray-400 transition-colors">
          Ask AI
        </a>
      </div>
    </div>
  </section>

  <!-- Product System -->
  <section id="products" class="max-w-6xl mx-auto py-20 px-6">
    <div class="max-w-3xl">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Product System</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">{products.length} products across 6 categories</h2>
      <p class="mt-4 text-gray-500">
        From paddleboards to rescue vessels, every product has structured specs for skill level, water type, and region availability.
      </p>
    </div>
    <div class="mt-12 grid md:grid-cols-3 gap-6">
      {categories.map(cat => (
        <div class="border border-gray-200 rounded-2xl p-6 hover:border-gray-300 transition-colors">
          <h3 class="text-xl font-semibold text-gray-900">{cat.name}</h3>
          <p class="text-sm text-gray-400 mt-1">{cat.count} products</p>
          <p class="text-gray-500 mt-3">{cat.waters}</p>
          <p class="text-sm text-gray-400 mt-2">Skill: {cat.skill}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Product List (SSOT) -->
  <section class="bg-gray-50 py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Product Catalog</span>
        <h2 class="mt-4 text-3xl font-semibold text-gray-900">All products</h2>
      </div>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map(p => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6">
            <h3 class="font-semibold text-gray-900">{p.name}</h3>
            <p class="text-gray-500 mt-2 text-sm">{p.desc}</p>
            <div class="mt-4 flex flex-wrap gap-2 text-xs">
              <span class="px-2 py-1 bg-gray-100 rounded-full text-gray-600">{p.category}</span>
              <span class="px-2 py-1 bg-gray-100 rounded-full text-gray-600">{p.skill}</span>
              {p.region.slice(0, 2).map(r => <span class="px-2 py-1 bg-gray-100 rounded-full text-gray-500">{r}</span>)}
            </div>
            {p.safety.length > 0 && (
              <p class="mt-3 text-xs text-amber-600">Safety: {p.safety.join(', ')}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="max-w-6xl mx-auto py-20 px-6">
    <div class="max-w-3xl">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Use Cases</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">Built for real water experiences</h2>
    </div>
    <div class="mt-12 grid md:grid-cols-4 gap-6">
      {useCases.map(u => (
        <div class="border border-gray-200 rounded-2xl p-6">
          <h3 class="font-semibold text-gray-900">{u.title}</h3>
          <p class="text-gray-500 mt-2 text-sm">{u.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Trust Layer -->
  <section class="bg-gray-50 py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Safety & Quality</span>
        <h2 class="mt-4 text-3xl font-semibold text-gray-900">Built to last, tested to perform</h2>
      </div>
      <div class="mt-12 grid md:grid-cols-4 gap-6">
        {trustPoints.map(t => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6">
            <h3 class="font-semibold text-gray-900">{t.title}</h3>
            <p class="text-gray-500 mt-2 text-sm">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Ask -->
  <section id="ask" class="py-20 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">AI Product Guide</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">Find the right product</h2>
      <p class="mt-4 text-gray-500">
        Ask our AI to compare products, recommend based on your skill level and water type,
        or check safety requirements. Powered by our structured product catalog.
      </p>
    </div>
    <div class="mt-10 max-w-2xl mx-auto px-6">
      <input id="q" class="w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-400" placeholder="E.g. Which SUP is good for a beginner on a lake?" />
      <button id="ask-btn" class="mt-4 px-6 py-3 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors">Ask AI</button>
      <pre id="out" class="mt-6 text-left text-sm text-gray-700 bg-white border border-gray-200 rounded-2xl p-6 hidden whitespace-pre-wrap"></pre>
    </div>
  </section>

  <!-- Contact / Distribution -->
  <section class="bg-gray-50 py-20 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Get in touch</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">Become a Wavefella Partner</h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        We work with global distributors in water sports retail. For distributors,
        retail partners, or product inquiries — let's talk.
      </p>
      <a href="/distributors" class="mt-8 inline-block px-6 py-3 bg-gray-900 text-white rounded-xl font-medium hover:bg-gray-800 transition-colors">
        Partner with us
      </a>
    </div>
  </section>
</Layout>

<script is:inline>
(function() {
  var btn = document.getElementById('ask-btn');
  var input = document.getElementById('q');
  var out = document.getElementById('out');
  if (!btn || !input || !out) return;

  btn.addEventListener('click', async function() {
    var q = input.value.trim();
    if (!q) return;
    out.classList.add('hidden');
    out.textContent = 'Thinking...';
    out.classList.remove('hidden');

    try {
      var res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: q }),
      });
      var data = await res.json();
      out.textContent = res.ok && data.answer ? data.answer : 'Error: ' + (data.error || 'Request failed');
    } catch (err) {
      out.textContent = 'Error: ' + err.message;
    }
  });
})();
</script>
