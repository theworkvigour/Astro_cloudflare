---
import Layout from '../../layouts/Layout.astro';
import { getRemainingNeurons, DAILY_NEURON_LIMIT } from '../../lib/ai-quota';

const remaining = await getRemainingNeurons();
const siteOrigin = 'https://alluredna.com';
---

<Layout metadata={{ title: 'GEO Internal Dashboard' }}>
  <main class="max-w-6xl mx-auto px-4 py-10">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">GEO Engine Dashboard</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1">Production-safe AI search optimization analysis</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
        <div class="text-sm text-gray-500 dark:text-gray-400">Daily Neuron Quota</div>
        <div class="text-2xl font-bold mt-1">{remaining} / {DAILY_NEURON_LIMIT}</div>
        <div class="text-xs text-gray-400 mt-1">Resets at 00:00 UTC</div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
        <div class="text-sm text-gray-500 dark:text-gray-400">Engine Status</div>
        <div class="text-2xl font-bold mt-1 text-green-600">Production Safe</div>
        <div class="text-xs text-gray-400 mt-1">v2.0 · Read-only · Edge native</div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
        <div class="text-sm text-gray-500 dark:text-gray-400">Default Site</div>
        <div class="text-lg font-mono mt-1 truncate">{siteOrigin}</div>
        <div class="text-xs text-gray-400 mt-1">Sitemap-based analysis</div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-xl font-semibold mb-3">Page Inspect</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Analyze a single page's GEO readiness</p>
        <form id="inspect-form" class="space-y-3" onsubmit="return inspectPage(event)">
          <input type="url" id="inspect-url" value={siteOrigin} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-sm font-mono" />
          <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg text-sm font-medium transition">Inspect Page</button>
        </form>
        <pre id="inspect-result" class="mt-4 text-xs bg-gray-50 dark:bg-gray-900 rounded-lg p-3 overflow-auto max-h-64 hidden"></pre>
      </section>

      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-xl font-semibold mb-3">Geo Score</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Get a quick GEO score for any URL</p>
        <form id="score-form" class="space-y-3" onsubmit="return getScore(event)">
          <input type="url" id="score-url" value={siteOrigin} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-sm font-mono" />
          <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white py-2 px-4 rounded-lg text-sm font-medium transition">Get Score</button>
        </form>
        <pre id="score-result" class="mt-4 text-xs bg-gray-50 dark:bg-gray-900 rounded-lg p-3 overflow-auto max-h-64 hidden"></pre>
      </section>

      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-xl font-semibold mb-3">Site Audit</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Full GEO audit across all sitemap pages</p>
        <form id="audit-form" class="space-y-3" onsubmit="return runAudit(event)">
          <input type="url" id="audit-site" value={siteOrigin} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-sm font-mono" />
          <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white py-2 px-4 rounded-lg text-sm font-medium transition">Run Audit</button>
        </form>
        <div id="audit-result" class="mt-4 text-xs bg-gray-50 dark:bg-gray-900 rounded-lg p-3 overflow-auto max-h-64 hidden"></div>
      </section>
    </div>

    <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
      <h2 class="text-xl font-semibold mb-3">API Reference</h2>
      <div class="space-y-3 text-sm">
        <div class="flex items-start gap-3">
          <code class="bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded text-xs font-mono shrink-0">GET /api/geo-score?url=</code>
          <span class="text-gray-600 dark:text-gray-400">Single page GEO score (score + grade)</span>
        </div>
        <div class="flex items-start gap-3">
          <code class="bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded text-xs font-mono shrink-0">GET /api/page-inspect?url=</code>
          <span class="text-gray-600 dark:text-gray-400">Full page analysis with rules, categories, recommendations</span>
        </div>
        <div class="flex items-start gap-3">
          <code class="bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded text-xs font-mono shrink-0">GET /api/site-audit?site=</code>
          <span class="text-gray-600 dark:text-gray-400">Full site audit (sitemap crawl + scoring + link graph)</span>
        </div>
        <div class="flex items-start gap-3">
          <code class="bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded text-xs font-mono shrink-0">GET /api/geo/status</code>
          <span class="text-gray-600 dark:text-gray-400">Engine status and quota info</span>
        </div>
      </div>
    </section>
  </main>

  <script>
    // @ts-nocheck
    const BASE = '';

    async function inspectPage(e) {
      e.preventDefault();
      const url = document.getElementById('inspect-url').value;
      const el = document.getElementById('inspect-result');
      el.classList.remove('hidden');
      el.textContent = 'Loading...';
      try {
        const res = await fetch(BASE + '/api/page-inspect?url=' + encodeURIComponent(url));
        el.textContent = JSON.stringify(await res.json(), null, 2);
      } catch (err) {
        el.textContent = 'Error: ' + err.message;
      }
      return false;
    }

    async function getScore(e) {
      e.preventDefault();
      const url = document.getElementById('score-url').value;
      const el = document.getElementById('score-result');
      el.classList.remove('hidden');
      el.textContent = 'Loading...';
      try {
        const res = await fetch(BASE + '/api/geo-score?url=' + encodeURIComponent(url));
        el.textContent = JSON.stringify(await res.json(), null, 2);
      } catch (err) {
        el.textContent = 'Error: ' + err.message;
      }
      return false;
    }

    async function runAudit(e) {
      e.preventDefault();
      const site = document.getElementById('audit-site').value;
      const el = document.getElementById('audit-result');
      el.classList.remove('hidden');
      el.innerHTML = '<div class="text-blue-600">Audit in progress... this may take a moment.</div>';
      try {
        const res = await fetch(BASE + '/api/site-audit?site=' + encodeURIComponent(site));
        const data = await res.json();
        el.innerHTML = '<pre class="text-xs overflow-auto max-h-96">' + JSON.stringify(data, null, 2) + '</pre>';
      } catch (err) {
        el.innerHTML = '<div class="text-red-600">Error: ' + err.message + '</div>';
      }
      return false;
    }
  </script>
</Layout>
