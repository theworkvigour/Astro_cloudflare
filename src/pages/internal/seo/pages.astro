---
import Layout from '~/layouts/Layout.astro';
import { contentV2Records } from '~/data/content-v2';
import { computePageHealth } from '~/lib/seo/health-score';
import { analyzeLinkDensity } from '~/lib/seo/link-optimizer';
import { computeAiCitationScore } from '~/lib/seo/geo-monitor';
import { suggestPositionImprovements } from '~/lib/seo/position-engine';
import { suggestGeoImprovements } from '~/lib/seo/geo-monitor';
import { suggestLinkImprovements } from '~/lib/seo/link-optimizer';

const healthScores = computePageHealth(contentV2Records);
const linkAnalysis = analyzeLinkDensity(contentV2Records);
const aiScores = computeAiCitationScore(contentV2Records);
const positionSuggestions = suggestPositionImprovements(contentV2Records);
const geoSuggestions = suggestGeoImprovements(contentV2Records);
const linkSuggestions = suggestLinkImprovements(contentV2Records);
---

<Layout metadata={{ title: 'Page Analysis — SEO Dashboard' }}>
  <main class="max-w-7xl mx-auto px-6 py-12">
    <div class="mb-8">
      <a href="/internal/seo" class="text-sm text-blue-600 hover:underline">&larr; Back to Dashboard</a>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mt-2">Page-Level Analysis</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1">Health scores, link density, AI readiness, optimization suggestions</p>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden mb-8">
      <div class="p-6 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold">All Pages — Health Scores (sorted worst first)</h2>
        <p class="text-sm text-gray-500 mt-1">Score breakdown: CTR (30) + Position (30) + Content (20) + Links (10) + AI (10) = 100</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-500">Page</th>
              <th class="text-center px-3 py-3 font-medium text-gray-500">CTR</th>
              <th class="text-center px-3 py-3 font-medium text-gray-500">Pos</th>
              <th class="text-center px-3 py-3 font-medium text-gray-500">Content</th>
              <th class="text-center px-3 py-3 font-medium text-gray-500">Links</th>
              <th class="text-center px-3 py-3 font-medium text-gray-500">AI</th>
              <th class="text-center px-3 py-3 font-medium text-gray-500">Total</th>
              <th class="text-center px-3 py-3 font-medium text-gray-500">Grade</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            {healthScores.map(h => {
              const gradeColors = { A: 'text-green-600 bg-green-50', B: 'text-blue-600 bg-blue-50', C: 'text-amber-600 bg-amber-50', D: 'text-orange-600 bg-orange-50', F: 'text-red-600 bg-red-50' };
              return (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-750">
                  <td class="px-4 py-3 font-medium max-w-xs truncate">{h.title.replace(/\(.*?\)/, '').trim()}</td>
                  <td class="px-3 py-3 text-center">{h.ctrScore}</td>
                  <td class="px-3 py-3 text-center">{h.positionScore}</td>
                  <td class="px-3 py-3 text-center">{h.contentDepthScore}</td>
                  <td class="px-3 py-3 text-center">{h.internalLinksScore}</td>
                  <td class="px-3 py-3 text-center">{h.aiStructureScore}</td>
                  <td class="px-3 py-3 text-center font-bold">{h.total}</td>
                  <td class="px-3 py-3 text-center">
                    <span class={`px-2 py-0.5 rounded-full text-xs font-bold ${gradeColors[h.grade]}`}>{h.grade}</span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold mb-4">Link Density Analysis</h2>
        <div class="space-y-2">
          {linkAnalysis.filter(l => l.score === 'poor').slice(0, 5).map(l => (
            <div class="flex items-center justify-between text-sm py-1.5 border-b border-gray-100 dark:border-gray-700 last:border-0">
              <span class="truncate flex-1">{l.title.replace(/\(.*?\)/, '').trim()}</span>
              <span class="ml-3 text-xs text-red-600 font-medium">{l.total} links</span>
            </div>
          ))}
        </div>
        {linkAnalysis.filter(l => l.score === 'poor').length === 0 && <p class="text-sm text-green-600">All pages have sufficient link density</p>}
      </section>

      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold mb-4">GEO AI Citation Scores</h2>
        <div class="space-y-2">
          {aiScores.slice(0, 5).map(a => (
            <div class="flex items-center justify-between text-sm py-1.5 border-b border-gray-100 dark:border-gray-700 last:border-0">
              <span class="truncate flex-1">{a.title.replace(/\(.*?\)/, '').trim()}</span>
              <div class="flex items-center gap-2 ml-3 shrink-0">
                <div class="w-16 bg-gray-100 dark:bg-gray-700 rounded-full h-1.5">
                  <div class={`h-1.5 rounded-full ${a.score >= 80 ? 'bg-green-500' : a.score >= 60 ? 'bg-blue-500' : a.score >= 40 ? 'bg-amber-500' : 'bg-red-500'}`} style={`width: ${a.score}%`}></div>
                </div>
                <span class="text-xs font-medium">{a.grade}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold mb-4">Quick Actions</h2>
        <div class="space-y-2">
          {positionSuggestions.slice(0, 3).map(s => (
            <div class="p-3 bg-amber-50 dark:bg-amber-950 rounded-lg text-sm">
              <div class="font-medium">{s.title.replace(/\(.*?\)/, '').trim()}</div>
              <div class="text-xs text-gray-500 mt-1">{s.suggestion}</div>
            </div>
          ))}
        </div>
        <a href="/internal/seo/workflow" class="mt-3 inline-block text-sm text-blue-600 hover:underline">View full workflow →</a>
      </section>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold mb-4">Link Optimization Suggestions</h2>
        <div class="space-y-2">
          {linkSuggestions.map(s => (
            <div class="p-3 bg-blue-50 dark:bg-blue-950 rounded-lg">
              <div class="text-sm font-medium">{s.title.replace(/\(.*?\)/, '').trim()}</div>
              <div class="text-xs text-gray-500 mt-1">{s.suggestion}</div>
              <div class="text-xs text-gray-400 mt-0.5">Priority: {s.priority} · Impact: {s.expectedImpact}</div>
            </div>
          ))}
          {linkSuggestions.length === 0 && <p class="text-sm text-green-600">All pages have sufficient internal links</p>}
        </div>
      </section>

      <section class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold mb-4">GEO Improvement Suggestions</h2>
        <div class="space-y-2">
          {geoSuggestions.slice(0, 5).map(s => (
            <div class="p-3 bg-purple-50 dark:bg-purple-950 rounded-lg">
              <div class="text-sm font-medium">{s.title.replace(/\(.*?\)/, '').trim()}</div>
              <div class="text-xs text-gray-500 mt-1">{s.suggestion}</div>
              <div class="text-xs text-gray-400 mt-0.5">Priority: {s.priority}</div>
            </div>
          ))}
          {geoSuggestions.length === 0 && <p class="text-sm text-green-600">All pages are GEO-ready</p>}
        </div>
      </section>
    </div>
  </main>
</Layout>
