---
import type { GetStaticPaths } from 'astro';
import merge from 'lodash.merge';
import type { ImageMetadata } from 'astro';
import NewsLayout from '~/layouts/NewsLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';

import { getCanonical, getPermalink } from '~/utils/permalinks';
import { isBlogEnabled, isBlogPostRouteEnabled, fetchPosts, blogPostRobots } from '~/utils/blog';
import { findImage } from '~/utils/images';
import type { MetaData } from '~/types';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';

export const prerender = true;

export const getStaticPaths = (async () => {
  if (!isBlogEnabled || !isBlogPostRouteEnabled) return [];
  const posts = await fetchPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;

const url = getCanonical(getPermalink(post.permalink, 'post'));
const image = (await findImage(post.image)) as ImageMetadata | string | undefined;

const pubDate = post.publishDate;
const modDate = post.updateDate || pubDate;
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  image: image ? String(image) : undefined,
  datePublished: pubDate instanceof Date ? pubDate.toISOString() : undefined,
  dateModified: modDate instanceof Date ? modDate.toISOString() : undefined,
  author: post.author ? { '@type': 'Person', name: post.author } : undefined,
  publisher: { '@type': 'Organization', name: 'Wavefella' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: {
      type: 'article',
      ...(image
        ? { images: [{ url: image, width: (image as ImageMetadata)?.width, height: (image as ImageMetadata)?.height }] }
        : {}),
    },
  },
  { ...(post?.metadata ? { ...post.metadata, canonical: post.metadata?.canonical || url } : {}) }
) as MetaData;
---

<NewsLayout metadata={metadata} breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'News', href: '/news' }, { name: post.title }]}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <SinglePost post={{ ...post, image: image }} url={url}>
    {post.Content && <post.Content />}
  </SinglePost>
  <ToBlogLink />
  <RelatedPosts post={post} />
</NewsLayout>
