---
import type { InferGetStaticPropsType } from 'astro';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import merge from 'lodash.merge';
import ProductLayout from '~/layouts/ProductLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import Tldr from '~/components/common/Tldr.astro';
import TrustBadges from '~/components/common/TrustBadges.astro';

import { findRelatedProducts, getStaticPathsProduct } from '~/utils/products';
import { findImage } from '~/utils/images';
import { SITE } from 'astrowind:config';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';
import { products as productRecords } from '~/data/products';
import { guides } from '~/data/guides';

export const prerender = true;

export const getStaticPaths = getStaticPathsProduct;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { product } = Astro.props as Props;
const rec = productRecords.find(p => p.id === product.slug);
const url = getCanonical(getPermalink(product.permalink, 'product'));
const image = await findImage(product.image);
const gallery = await Promise.all(
  (product.gallery ?? []).map(async (g) => ({
    raw: await findImage(g.url),
    alt: g.alt || product.title,
  }))
);
const related = await findRelatedProducts(product, 3);
const relatedGuides = rec
  ? guides.filter(g => g.relatedProducts.includes(rec.id)).slice(0, 3)
  : [];

const defaultTitle = product.categoryLabel
  ? `${product.title} — ${product.categoryLabel} | ${SITE.name}`
  : `${product.title} | ${SITE.name}`;
const defaultDesc = (product.summary ?? product.description)
  ? `${product.summary ?? product.description} — Contact ${SITE.name} for pricing, specs, and ordering.`
  : `Explore the ${product.title} from ${SITE.name}. Contact us for pricing, technical specs, and ordering information.`;

const metadata = merge(
  {
    title: defaultTitle,
    description: defaultDesc,
    canonical: url,
    robots: { index: !product.draft, follow: true },
    openGraph: {
      type: 'website',
      ...(image
        ? { images: [{ url: image, width: 1200, height: 630 }] }
        : {}),
    },
  },
  product.metadata ? { ...product.metadata, canonical: product.metadata.canonical || url } : {}
) as MetaData;

const productCrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Products', href: '/products' },
  ...(product.categoryLabel ? [{ name: product.categoryLabel, href: `/products?category=${product.category}` }] : []),
  { name: product.title },
];

const specRows = product.specs ?? [];
---

<ProductLayout metadata={metadata} breadcrumbs={productCrumbs}>
  <JsonLd type="Product" product={{
    name: product.title,
    description: product.summary ?? product.description ?? '',
    sku: product.sku,
    image: image ? String(image) : undefined,
    url: String(url || ''),
    category: product.categoryLabel,
    brandName: SITE.name,
    ...(product.price ? { price: { amount: product.price.amount, currency: product.price.currency }, inStock: product.inStock } : {}),
  }} />
  <JsonLd type="BreadcrumbList" breadcrumbs={productCrumbs.map(c => ({ name: c.name, href: c.href }))} />

  <!-- Hero Image -->
  <section class="relative h-[70vh] min-h-[500px] flex items-end overflow-hidden bg-gray-100 dark:bg-slate-900">
    {
      image ? (
        typeof image === 'string' ? (
          <img src={image} alt={product.title} class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
        ) : (
          <Image
            src={image as ImageMetadata}
            alt={product.title}
            class="absolute inset-0 w-full h-full object-cover"
            widths={[1024, 2048]}
            width={2048}
            height={1365}
            sizes="100vw"
            format="webp"
            loading="eager"
            decoding="async"
          />
        )
      ) : null
    }
    <div class="absolute inset-0 bg-gradient-to-t from-[#001830]/80 via-[#001830]/20 to-transparent"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 pb-16 md:pb-20 w-full">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 text-sm text-white/60 mb-4">
          {product.categoryLabel && <span class="font-medium tracking-wider uppercase">{product.categoryLabel}</span>}
          {product.sku && <><span aria-hidden="true">·</span><span class="font-mono">{product.sku}</span></>}
        </div>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-[1.1]">{product.title}</h1>
        {product.summary && <p class="mt-4 text-lg text-white/80 max-w-xl leading-relaxed">{product.summary}</p>}
      </div>
    </div>
  </section>

  <!-- TLDR (AI-crawlable) -->
  {rec && (
    <section class="max-w-6xl mx-auto px-6 -mt-8 relative z-20">
      <Tldr
        summary={rec.definition}
        points={[`${rec.audience}`, `Use cases: ${rec.ai_use_cases.slice(0, 3).join(', ')}`]}
      />
    </section>
  )}

  <!-- Why This Exists (Problem) -->
  {rec && rec.problem && (
    <section class="section-premium bg-white dark:bg-slate-950" data-ai-block="problem">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-3xl mx-auto reveal">
          <span class="text-sm font-semibold uppercase tracking-wider text-sky-600 dark:text-blue-400 mb-2 block">Why this exists</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-6">The problem it solves</h2>
          <p class="text-lg text-gray-600 dark:text-slate-400 leading-relaxed">{rec.problem}</p>
        </div>
      </div>
    </section>
  )}

  <!-- Use Cases -->
  {rec && rec.ai_use_cases.length > 0 && (
    <section class="section-premium bg-gray-50/50 dark:bg-slate-900/50" data-ai-block="use-case">
      <div class="max-w-6xl mx-auto px-6">
        <div class="reveal max-w-3xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-8 text-center">Use cases</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {rec.ai_use_cases.map(uc => (
              <div class="flex items-start gap-3 p-5 rounded-xl bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700">
                <span class="w-2 h-2 mt-2 rounded-full bg-sky-500 flex-shrink-0"></span>
                <div>
                  <p class="text-sm text-gray-700 dark:text-slate-300">{uc}</p>
                </div>
              </div>
            ))}
            <div class="flex items-start gap-3 p-5 rounded-xl bg-sky-50 dark:bg-sky-900/30 border border-sky-100 dark:border-sky-800">
              <span class="w-2 h-2 mt-2 rounded-full bg-sky-500 flex-shrink-0"></span>
              <div>
                <p class="text-sm font-semibold text-sky-800 dark:text-sky-300">Skill level</p>
                <p class="text-sm text-sky-700 dark:text-sky-400 capitalize">{rec.skill}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Story Section -->
  {product.description && (
    <section class="section-premium bg-white dark:bg-slate-950">
      <div class="max-w-6xl mx-auto px-6">
        <div class="content-max-w reveal">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-6">Story</h2>
          <p class="text-lg text-gray-600 dark:text-slate-400 leading-relaxed whitespace-pre-line">{product.description}</p>
        </div>
      </div>
    </section>
  )}

  <!-- Comparison -->
  {rec && rec.ai_comparison && (
    <section class="section-premium bg-white dark:bg-slate-950" data-ai-block="comparison">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-3xl mx-auto reveal">
          <span class="text-sm font-semibold uppercase tracking-wider text-sky-600 dark:text-blue-400 mb-2 block">Comparison</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-6">How it compares</h2>
          <p class="text-lg text-gray-600 dark:text-slate-400 leading-relaxed">{rec.ai_comparison}</p>
        </div>
      </div>
    </section>
  )}

  <!-- Features -->
  {specRows.length > 0 && (
    <section class="section-premium bg-gray-50/50 dark:bg-slate-900/50">
      <div class="max-w-6xl mx-auto px-6">
        <div class="reveal">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-12 text-center">Specifications</h2>
          <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
            {specRows.slice(0, 8).map((s) => (
              <div class="flex items-start gap-4 p-5 rounded-xl bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700">
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <Icon name="tabler:check" class="w-5 h-5 text-primary" />
                </div>
                <div>
                  <div class="text-sm font-semibold text-default dark:text-slate-200">{s.label}</div>
                  <div class="text-sm text-gray-500 dark:text-slate-400 mt-0.5">{s.value}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Trust Badges -->
  <section class="section-premium bg-gray-50/50 dark:bg-slate-900/50">
    <div class="max-w-6xl mx-auto px-6">
      <TrustBadges layout="row" />
    </div>
  </section>

  <!-- Gallery -->
  {gallery.length > 0 && (
    <section class="section-premium bg-white dark:bg-slate-950">
      <div class="max-w-6xl mx-auto px-6">
        <div class="reveal">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-12 text-center">Gallery</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {gallery.map((g) => (
              <div class="image-zoom rounded-2xl overflow-hidden bg-gray-50 dark:bg-slate-800 aspect-[4/3]">
                {g.raw && (
                  typeof g.raw === 'string' ? (
                    <img src={g.raw} alt={g.alt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
                  ) : (
                    <Image
                      src={g.raw as ImageMetadata}
                      alt={g.alt}
                      class="w-full h-full object-cover"
                      widths={[480, 768]}
                      width={768}
                      height={576}
                      format="webp"
                      loading="lazy"
                      decoding="async"
                    />
                  )
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Content (MDX) -->
  {product.Content && (
    <section class="section-premium bg-gray-50/50 dark:bg-slate-900/50">
      <div class="max-w-3xl mx-auto px-6 reveal">
        <div class="prose prose-lg dark:prose-invert prose-headings:font-heading prose-headings:tracking-tight prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-xl">
          <product.Content />
        </div>
      </div>
    </section>
  )}

  <!-- AI Summary (visible to users + AI crawlers) -->
  {rec && (
    <>
      <section class="ai-summary bg-blue-50 dark:bg-slate-800/50 border-l-4 border-blue-500 rounded-r-xl px-6 py-5 max-w-6xl mx-auto mt-8" aria-label="AI summary">
        <div class="flex items-start gap-3">
          <span class="text-blue-600 dark:text-blue-400 text-xs font-semibold uppercase tracking-wider flex-shrink-0 mt-0.5">AI Overview</span>
          <div class="space-y-2 text-sm text-gray-700 dark:text-slate-300 leading-relaxed">
            <p>{rec.definition}</p>
            <p><strong>How it works:</strong> {rec.howItWorks}</p>
            <p><strong>Best for:</strong> {rec.audience}</p>
            <p><strong>Use cases:</strong> {rec.ai_use_cases.join(' · ')}</p>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      {rec.ai_faq.length > 0 && (
        <section class="section-premium bg-white dark:bg-slate-950">
          <div class="max-w-6xl mx-auto px-6">
            <div class="reveal max-w-4xl mx-auto">
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-8 text-center">Frequently Asked Questions</h2>
              <div class="space-y-4">
                {rec.ai_faq.map(f => (
                  <details class="group rounded-xl border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/50 open:bg-white dark:open:bg-slate-800 transition-colors">
                    <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-sm font-semibold text-default dark:text-slate-200 list-none">
                      {f.q}
                      <span class="shrink-0 ml-2 text-gray-400 group-open:rotate-180 transition-transform">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                      </span>
                    </summary>
                    <div class="px-5 pb-4 text-sm text-gray-600 dark:text-slate-400 leading-relaxed border-t border-gray-100 dark:border-slate-700 pt-3 mt-0">
                      {f.a}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- Schema FAQ -->
      <JsonLd type="FAQPage" faqs={rec.ai_faq} />

      <!-- Hidden AI data blocks (machine-readable) -->
      <section class="sr-only" aria-hidden="true">
        <div data-ai-block="definition">
          <p>{rec.definition}</p>
          <p>Problem it solves: {rec.problem}</p>
          <p>How it works: {rec.howItWorks}</p>
          <p>Target audience: {rec.audience}</p>
        </div>
        <div data-ai-block="use-case">
          <p>Use cases: {rec.ai_use_cases.join('; ')}</p>
          <p>Environments: {rec.environment.join(', ')}</p>
          <p>Water conditions: {rec.water_condition.join(', ')}</p>
          <p>Skill level: {rec.skill}</p>
        </div>
        <div data-ai-block="specification">
          {Object.entries(rec.ai_specs).map(([k, v]) => (<p data-spec={k}>{k}: {v}</p>))}
        </div>
        <div data-ai-block="comparison"><p>{rec.ai_comparison}</p></div>
        <div data-ai-block="faq">
          {rec.ai_faq.map(f => (<p><strong>Q:</strong> {f.q} <strong>A:</strong> {f.a}</p>))}
        </div>
        <div data-ai-block="constraint">
          <p>Safety rules: {rec.safety_rules.join('; ')}</p>
          <p>Safety level: {rec.safety_level}</p>
          <p>Regions: {rec.region.join(', ')}</p>
        </div>
      </section>
    </>
  )}

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="section-premium bg-white dark:bg-slate-950">
      <div class="max-w-6xl mx-auto px-6 reveal">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-12 text-center">Related products</h2>
        <div class="grid gap-6 md:grid-cols-3">
          {related.map((p) => <ProductCard product={p} showMeta={false} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Related Guides -->
  {relatedGuides.length > 0 && (
    <section class="section-premium bg-gray-50/50 dark:bg-slate-900/50">
      <div class="max-w-6xl mx-auto px-6 reveal">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-default dark:text-slate-100 mb-8 text-center">Related guides</h2>
        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {relatedGuides.map(g => (
            <a href={`/guides/${g.slug}`} class="block p-6 bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 hover:shadow-md transition-shadow">
              <div class="flex items-center gap-2 text-xs mb-2">
                <span class="px-2 py-0.5 bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-300 rounded-full capitalize">{g.difficulty}</span>
              </div>
              <h3 class="text-base font-semibold text-default dark:text-slate-200">{g.title}</h3>
              <p class="mt-1 text-sm text-gray-500 dark:text-slate-400 line-clamp-2">{g.description}</p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-sky-600 dark:text-blue-400">Read guide →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="section-premium bg-primary dark:bg-blue-900">
    <div class="max-w-3xl mx-auto px-6 text-center reveal">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-4">Interested in {product.title}?</h2>
      <p class="text-lg text-white/70 mb-8 max-w-xl mx-auto">Contact our team for detailed specifications, pricing, and ordering information.</p>
      <a
        href={`/contact?product=${encodeURIComponent(product.title)}`}
        class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary font-semibold rounded-full hover:bg-gray-50 transition-all shadow-xl hover:shadow-2xl hover:-translate-y-0.5"
      >
        <Icon name="tabler:message-circle" class="w-5 h-5" />
        Request a quote
      </a>
    </div>
  </section>

  <ToBlogLink />
</ProductLayout>
