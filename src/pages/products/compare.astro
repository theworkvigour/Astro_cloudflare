---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { getProducts } from '~/utils/products';

const metadata = {
  title: `Product Comparison — ${SITE.name}`,
  description: 'Compare Wavefella inflatable SUPs, kayaks, dinghies, RIBs, and accessories side by side. Length, width, weight, capacity, and more.',
};

const products = await getProducts();

const comparisonRows = [
  { label: 'Category', key: 'categoryLabel' as const, transform: (v: string) => v },
  { label: 'Length', key: 'length' as const, getter: (p: typeof products[number]) => {
    const s = p.specs?.find(s => s.label.toLowerCase().includes('length'));
    return s?.value || '-';
  }},
  { label: 'Width', key: 'width' as const, getter: (p: typeof products[number]) => {
    const s = p.specs?.find(s => s.label.toLowerCase().includes('width'));
    return s?.value || '-';
  }},
  { label: 'Weight', key: 'weight' as const, getter: (p: typeof products[number]) => {
    const s = p.specs?.find(s => s.label.toLowerCase().includes('weight'));
    return s?.value || '-';
  }},
  { label: 'Max Load', key: 'maxLoad' as const, getter: (p: typeof products[number]) => {
    const s = p.specs?.find(s => s.label.toLowerCase().includes('load') || s.label.toLowerCase().includes('capacity'));
    return s?.value || '-';
  }},
  { label: 'Material', key: 'material' as const, getter: (p: typeof products[number]) => {
    const s = p.specs?.find(s => s.label.toLowerCase().includes('material'));
    return s?.value || 'PVC';
  }},
  { label: 'Skill Level', key: 'skill' as const, getter: (p: typeof products[number]) => {
    const s = p.specs?.find(s => s.label.toLowerCase().includes('skill'));
    return s?.value || '-';
  }},
  { label: 'Price', key: 'price' as const, getter: (p: typeof products[number]) => {
    return p.price?.amount ? `$${p.price.amount}` : 'Contact';
  }},
];
---

<Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto py-24 px-6">
    <a href="/products" class="text-sm text-sky-600 hover:text-sky-700">← Products</a>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">Product Comparison</h1>
    <p class="mt-4 text-lg text-gray-500">Compare all Wavefella products side by side. Find the right board, boat, or accessory for your needs.</p>

    <div class="mt-12 overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr>
            <th class="sticky left-0 bg-white z-10 px-4 py-3 text-left font-semibold text-gray-900 border-b-2 border-gray-200 min-w-[140px]">Specification</th>
            {products.map(p => (
              <th class="px-4 py-3 text-center font-semibold text-gray-900 border-b-2 border-gray-200 min-w-[120px]">
                <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">{p.categoryLabel}</div>
                <a href={`/products/${p.slug}`} class="hover:text-sky-600">{p.title}</a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {comparisonRows.map((row, i) => (
            <tr class={i % 2 === 0 ? 'bg-gray-50' : 'bg-white'}>
              <td class="sticky left-0 px-4 py-3 font-medium text-gray-700 border-b border-gray-200" style={i % 2 === 0 ? 'background:#f9fafb' : 'background:white'}>{row.label}</td>
              {products.map(p => {
                const value = row.getter ? row.getter(p) : (p as any)[row.key];
                return (
                  <td class="px-4 py-3 text-center text-gray-600 border-b border-gray-200">{value || '-'}</td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      {products.map(p => (
        <a href={`/products/${p.slug}`} class="block p-4 bg-white border border-gray-200 rounded-xl hover:shadow-md transition-shadow text-center">
          <div class="text-xs uppercase tracking-wider text-sky-600 font-medium">{p.categoryLabel}</div>
          <div class="mt-1 font-semibold text-gray-900">{p.title}</div>
          {p.price?.amount && <div class="mt-1 text-sm text-gray-500">${p.price.amount}</div>}
          <div class="mt-2 text-xs text-sky-600 hover:underline">View details →</div>
        </a>
      ))}
    </div>

    <section class="sr-only" data-ai-block="definition" aria-hidden="true">
      <p>Wavefella product comparison table covering {products.length} products across {['rib','inflatable','accessory','service'].filter(c => products.some(p => p.category === c)).length} categories. Compare length, width, weight, max load, material, and price.</p>
    </section>
  </section>
</Layout>
