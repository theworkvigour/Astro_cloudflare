---
import { SITE, METADATA } from 'astrowind:config';
import { defaultLang, languages } from '../../i18n/config';
import { removeLang, localizePath } from '../../i18n/utils';

export interface Props {
  title: string;
  description: string;
  lang?: string;
  canonical?: string;
  image?: string;
  keywords?: string;
  noIndex?: boolean;
  noFollow?: boolean;
  ogType?: string;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const {
  title,
  description,
  lang = defaultLang,
  canonical,
  image,
  keywords,
  noIndex,
  noFollow,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

const siteUrl = String(SITE.site || '').replace(/\/+$/, '');
const defaultImage = image || METADATA?.openGraph?.images?.[0]?.url || '/images/default.png';
const fullCanonical = canonical
  ? (canonical.startsWith('http') ? canonical : `${siteUrl}${canonical}`)
  : siteUrl;
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
{keywords && <meta name="keywords" content={keywords} />}
{noIndex && <meta name="robots" content="noindex" />}
{!noIndex && noFollow && <meta name="robots" content="nofollow" />}
{!noIndex && !noFollow && <meta name="robots" content="index, follow" />}

<link rel="canonical" href={fullCanonical} />

{Object.keys(languages).map(l => (
  <link rel="alternate" hreflang={l} href={`${siteUrl}${localizePath(removeLang(canonical || '/'), l)}`} />
))}
<link rel="alternate" hreflang="x-default" href={`${siteUrl}${localizePath(removeLang(canonical || '/'), defaultLang)}`} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={defaultImage.startsWith('http') ? defaultImage : `${siteUrl}${defaultImage}`} />
<meta property="og:url" content={fullCanonical} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE.name || 'Wavefella'} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={defaultImage.startsWith('http') ? defaultImage : `${siteUrl}${defaultImage}`} />

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{author && <meta property="article:author" content={author} />}

<html lang={lang} />
