---
interface Props {
  prefix: string;
  data?: {
    title?: string;
    information?: string;
  };
}
const { prefix, data = {} } = Astro.props;
const d = data ?? {};
---
<div class="space-y-4" data-section-type="blog_latest" data-prefix={prefix}>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
    <input type="text" name="title" value={d.title ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Information <span class="text-xs text-gray-500">(supports HTML tags)</span></label>
    <textarea name="information" rows="4" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono">{d.information ?? ''}</textarea>
  </div>
  <p class="text-xs text-gray-500">Blog posts come from <code>src/content/news/</code> (managed in Posts), this block only controls the header title and description.</p>
</div>
