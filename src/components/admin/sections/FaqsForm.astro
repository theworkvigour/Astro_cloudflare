---
interface Props {
  prefix: string;
  data?: {
    title?: string;
    subtitle?: string;
    tagline?: string;
    columns?: number;
    items?: Array<{ title?: string; description?: string; icon?: string }>;
  };
}
const { prefix, data = {} } = Astro.props;
const d = data ?? {};
---
<div class="space-y-4" data-section-type="faqs" data-prefix={prefix}>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
    <input type="text" name="title" value={d.title ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subtitle <span class="text-xs text-gray-500">(supports HTML)</span></label>
    <textarea name="subtitle" rows="2" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono">{d.subtitle ?? ''}</textarea>
  </div>
  <div>
    <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Columns</label>
    <select name="columns" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm">
      <option value="1" selected={d.columns === 1}>1 column</option>
      <option value="2" selected={(d.columns ?? 2) === 2}>2 columns</option>
      <option value="3" selected={d.columns === 3}>3 columns</option>
    </select>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Items (FAQs)</label>
      <button type="button" data-add-item class="text-xs text-blue-600 dark:text-blue-400 hover:underline">+ Add FAQ</button>
    </div>
    <div data-items-list class="space-y-3">
      {(d.items ?? []).map((it) => (
        <div data-item-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
          <div class="flex gap-2">
            <input type="text" name="itemTitle" value={it.title ?? ''} placeholder="Question" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <input type="text" name="itemIcon" value={it.icon ?? ''} placeholder="Icon (optional)" class="w-48 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <button type="button" data-remove-item class="text-xs text-red-600 dark:text-red-400 hover:underline">Delete</button>
          </div>
          <textarea name="itemDescription" rows="2" placeholder="Answer (supports HTML)" class="w-full px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono">{it.description ?? ''}</textarea>
        </div>
      ))}
    </div>
    <template data-item-template>
      <div data-item-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
        <div class="flex gap-2">
          <input type="text" name="itemTitle" placeholder="Question" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input type="text" name="itemIcon" placeholder="Icon (optional)" class="w-48 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <button type="button" data-remove-item class="text-xs text-red-600 dark:text-red-400 hover:underline">Delete</button>
        </div>
        <textarea name="itemDescription" rows="2" placeholder="Answer (supports HTML)" class="w-full px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"></textarea>
      </div>
    </template>
  </div>
</div>
