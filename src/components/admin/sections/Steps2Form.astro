---
interface Props {
  prefix: string;
  data?: {
    title?: string;
    subtitle?: string;
    tagline?: string;
    isReversed?: boolean;
    callToAction?: { text?: string; href?: string; variant?: string };
    items?: Array<{ title?: string; description?: string; icon?: string }>;
  };
}
const { prefix, data = {} } = Astro.props;
const d = data ?? {};
---
<div class="space-y-4" data-section-type="steps2" data-prefix={prefix}>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tagline</label>
    <input type="text" name="tagline" value={d.tagline ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
    <input type="text" name="title" value={d.title ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
  </div>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subtitle <span class="text-xs text-gray-500">(supports HTML)</span></label>
    <textarea name="subtitle" rows="2" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono">{d.subtitle ?? ''}</textarea>
  </div>
  <label class="flex items-center gap-2 text-sm">
    <input type="checkbox" name="isReversed" checked={!!d.isReversed} class="rounded" />
    <span class="text-gray-700 dark:text-gray-300">Reversed layout (isReversed)</span>
  </label>
  <div>
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">CallToAction (top button, optional)</label>
    <div class="grid grid-cols-3 gap-2">
      <input type="text" name="ctaText" value={d.callToAction?.text ?? ''} placeholder="Button text" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
      <input type="text" name="ctaHref" value={d.callToAction?.href ?? ''} placeholder="Link URL" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
      <input type="text" name="ctaVariant" value={d.callToAction?.variant ?? ''} placeholder="variant" class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
    </div>
  </div>
  <div>
    <div class="flex items-center justify-between mb-2">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Items</label>
      <button type="button" data-add-item class="text-xs text-blue-600 dark:text-blue-400 hover:underline">+ Add step</button>
    </div>
    <div data-items-list class="space-y-3">
      {(d.items ?? []).map((it) => (
        <div data-item-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
          <div class="flex gap-2">
            <input type="text" name="itemTitle" value={it.title ?? ''} placeholder="Title" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <input type="text" name="itemIcon" value={it.icon ?? ''} placeholder="Icon" class="w-48 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <button type="button" data-remove-item class="text-xs text-red-600 dark:text-red-400 hover:underline">Delete</button>
          </div>
          <textarea name="itemDescription" rows="2" placeholder="Description" class="w-full px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm">{it.description ?? ''}</textarea>
        </div>
      ))}
    </div>
    <template data-item-template>
      <div data-item-row class="rounded-md border border-gray-200 dark:border-gray-700 p-3 space-y-2 bg-gray-50 dark:bg-gray-900/50">
        <div class="flex gap-2">
          <input type="text" name="itemTitle" placeholder="Title" class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input type="text" name="itemIcon" placeholder="Icon" class="w-48 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <button type="button" data-remove-item class="text-xs text-red-600 dark:text-red-400 hover:underline">Delete</button>
        </div>
        <textarea name="itemDescription" rows="2" placeholder="Description" class="w-full px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"></textarea>
      </div>
    </template>
  </div>
</div>
