---
import type { CollectionFormData } from './types';

interface Props {
  mode: 'create' | 'edit';
  initial: CollectionFormData;
  filename?: string;
  sha?: string;
  path?: string;
}

const { mode, initial, filename, sha, path } = Astro.props;

const fm = initial.frontmatter;
const seo = (fm.metadata as Record<string, unknown> | undefined) ?? {};
const seoRobots = (seo.robots as Record<string, unknown> | undefined) ?? {};
const seoOg = (seo.openGraph as Record<string, unknown> | undefined) ?? {};
const seoTwitter = (seo.twitter as Record<string, unknown> | undefined) ?? {};

const tags = Array.isArray(fm.tags) ? (fm.tags as string[]) : [];
const gallery = Array.isArray(fm.gallery) ? (fm.gallery as Array<{ url: string; alt?: string }>) : [];
const specs = Array.isArray(fm.specs) ? (fm.specs as Array<{ label: string; value: string }>) : [];
const ogImages = Array.isArray(seoOg.images) ? (seoOg.images as Array<{ url: string; width?: number; height?: number }>) : [];
const price = (fm.price as Record<string, unknown> | undefined) ?? {};
---
<form id="entry-form" class="space-y-6" data-mode={mode}>
  <input type="hidden" name="_path" value={path ?? ''} />
  <input type="hidden" name="_sha" value={sha ?? ''} />
  <input type="hidden" name="_filename" value={filename ?? ''} />

  <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
    <h2 class="text-lg font-semibold">Basic Info</h2>
    <div>
      <label class="block text-sm font-medium mb-1" for="title">Title <span class="text-red-500">*</span></label>
      <input id="title" name="title" type="text" required value={(fm.title as string) ?? ''}
        class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1" for="publishDate">Publish Date</label>
        <input id="publishDate" name="publishDate" type="date" value={(fm.publishDate as string) ?? ''}
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" for="category">Category</label>
        <input id="category" name="category" type="text" list="category-list" value={(fm.category as string) ?? ''}
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
        <datalist id="category-list">
          <option value="documentation" />
          <option value="tutorials" />
          <option value="news" />
        </datalist>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" for="author">Author</label>
        <input id="author" name="author" type="text" value={(fm.author as string) ?? ''}
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1" for="excerpt">Excerpt</label>
      <textarea id="excerpt" name="excerpt" rows="3" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none text-sm">{(fm.excerpt as string) ?? ''}</textarea>
    </div>
    <div>
        <label class="block text-sm font-medium mb-1" for="image">Cover Image URL</label>
      <input id="image" name="image" type="url" value={(fm.image as string) ?? ''}
        class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none font-mono text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Tags</label>
      <div id="tags-list" class="space-y-2">
        {tags.map((t, i) => (
          <div class="flex items-center gap-2" data-repeater-row>
            <input type="text" name="tags" value={t} class="flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
            <button type="button" data-repeater-remove class="text-red-500 hover:underline text-xs">Delete</button>
          </div>
        ))}
      </div>
      <button type="button" data-repeater-add="tags-list" data-template="tag" class="mt-2 text-sm text-blue-600 dark:text-blue-400 hover:underline">+ Add Tag</button>
    </div>
    <div class="flex items-center gap-6">
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="draft" value="true" checked={fm.draft === true} class="rounded" />
        Draft (Unpublished)
      </label>
    </div>
  </div>

  <details class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 group" open>
    <summary class="text-lg font-semibold cursor-pointer list-none flex items-center justify-between">
      <span>SEO / Metadata</span>
      <span class="text-sm text-gray-400 group-open:hidden">Click to expand</span>
      <span class="text-sm text-gray-400 hidden group-open:inline">Click to collapse</span>
    </summary>
    <div class="mt-4 space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1" for="seo-title">Meta Title</label>
        <input id="seo-title" name="seoTitle" type="text" value={(seo.title as string) ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" for="seo-desc">Meta Description</label>
        <textarea id="seo-desc" name="seoDescription" rows="2" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm">{(seo.description as string) ?? ''}</textarea>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" for="seo-canonical">Canonical URL</label>
        <input id="seo-canonical" name="seoCanonical" type="url" value={(seo.canonical as string) ?? ''} class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
      </div>
      <div class="flex items-center gap-6 text-sm">
        <label class="flex items-center gap-2"><input type="checkbox" name="seoRobotIndex" value="true" checked={seoRobots.index !== false} class="rounded" /> Index</label>
        <label class="flex items-center gap-2"><input type="checkbox" name="seoRobotFollow" value="true" checked={seoRobots.follow !== false} class="rounded" /> Follow</label>
        <label class="flex items-center gap-2"><input type="checkbox" name="seoIgnoreTitleTemplate" value="true" checked={seo.ignoreTitleTemplate === true} class="rounded" /> Ignore Title Template</label>
      </div>
      <div class="border-t border-gray-200 dark:border-gray-800 pt-4">
        <div class="text-sm font-medium mb-2">Open Graph</div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <input name="seoOgUrl" type="url" placeholder="OG URL" value={(seoOg.url as string) ?? ''} class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input name="seoOgSiteName" type="text" placeholder="OG Site Name" value={(seoOg.siteName as string) ?? ''} class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input name="seoOgLocale" type="text" placeholder="OG Locale (en_US)" value={(seoOg.locale as string) ?? ''} class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input name="seoOgType" type="text" placeholder="OG Type (website/article)" value={(seoOg.type as string) ?? ''} class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
        </div>
      </div>
      <div class="border-t border-gray-200 dark:border-gray-800 pt-4">
        <div class="text-sm font-medium mb-2">Twitter Card</div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <input name="seoTwitterHandle" type="text" placeholder="Handle (@site)" value={(seoTwitter.handle as string) ?? ''} class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input name="seoTwitterSite" type="text" placeholder="Site (@site)" value={(seoTwitter.site as string) ?? ''} class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
          <input name="seoTwitterCardType" type="text" placeholder="Card Type" value={(seoTwitter.cardType as string) ?? ''} class="px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm" />
        </div>
      </div>
    </div>
  </details>

  <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6">
      <div class="flex items-center justify-between mb-2">
        <label class="block text-sm font-medium" for="body">Content (Markdown, MDX supported)</label>
        <span class="text-xs text-gray-400" id="body-stats">0 characters</span>
      </div>
    <textarea id="body" name="body" rows="22" required class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">{initial.body}</textarea>
  </div>

  <div class="sticky bottom-0 -mx-6 px-6 py-4 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 flex items-center justify-end gap-3">
    <a href="/keystatic/posts" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline">Cancel</a>
    <button type="submit" id="submit-btn" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md disabled:opacity-50">
      {mode === 'create' ? 'Create & Push' : 'Save & Push'}
    </button>
  </div>
</form>

<script is:inline>
  (function () {
    const form = document.getElementById('entry-form');
    if (!form) return;
    const body = document.getElementById('body');
    const stats = document.getElementById('body-stats');
    if (body && stats) {
      const update = () => { stats.textContent = (body.value.length).toLocaleString() + ' characters'; };
      body.addEventListener('input', update);
      update();
    }

    document.querySelectorAll('[data-repeater-add]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-repeater-add');
        const list = document.getElementById(target);
        if (!list) return;
        const row = document.createElement('div');
        row.className = 'flex items-center gap-2';
        row.setAttribute('data-repeater-row', '');
        const input = document.createElement('input');
        input.type = 'text';
        input.name = 'tags';
        input.className = 'flex-1 px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm';
        const remove = document.createElement('button');
        remove.type = 'button';
        remove.setAttribute('data-repeater-remove', '');
            remove.className = 'text-red-500 hover:underline text-xs';
            remove.textContent = 'Delete';
        row.appendChild(input);
        row.appendChild(remove);
        list.appendChild(row);
      });
    });

    document.addEventListener('click', (e) => {
      const t = e.target instanceof Element ? e.target.closest('[data-repeater-remove]') : null;
      if (!t) return;
      const row = t.closest('[data-repeater-row]');
      if (row) row.remove();
    });
  })();
</script>
