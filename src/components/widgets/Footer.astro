---
import { Icon } from 'astro-icon/components';
import branding from '~/data/site/branding.yaml';
import { getHomePermalink } from '~/utils/permalinks';
import { getSeoSettings } from '~/utils/seo-settings';
import { getLangFromUrl } from '~/i18n/utils';
import { defaultLang } from '~/i18n/config';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote, theme = 'light' } = Astro.props;

const seo = await getSeoSettings();

const ksSocialLinks: Array<Link> = (seo.socialLinks || [])
  .filter((s) => s?.url && s.url !== '#')
  .map((s) => ({
    ariaLabel: s.ariaLabel || s.platform,
    href: s.url || '#',
    icon: s.icon || '',
  }));

const mergedSocialLinks = (ksSocialLinks.length > 0
  ? [
      ...ksSocialLinks,
      ...socialLinks.filter((s) => !ksSocialLinks.find((k) => k.ariaLabel?.toLowerCase() === s.ariaLabel?.toLowerCase())),
    ]
  : socialLinks).filter((s) => s?.href && s.href !== '#');

const entityForHref = (href?: string): string => {
  if (!href) return 'page';
  const path = href.replace(/^\/+/g, '');
  if (path === '' || path === 'home') return 'brand';
  if (path.startsWith('products') || path.startsWith('size-guide')) return 'product';
  if (path.startsWith('technology') || path.startsWith('randdcenter')) return 'technology';
  if (path.startsWith('safety')) return 'safety';
  if (path.startsWith('guides')) return 'guide';
  if (path.startsWith('news')) return 'article';
  if (path.startsWith('about')) return 'brand';
  if (path.startsWith('services') || path.startsWith('pricing') || path.startsWith('contact')) return 'service';
  return 'page';
};

const currentLocale = getLangFromUrl(Astro.url);

const LOCALIZED_ROUTES = new Set(['/products', '/guides', '/faq', '/v2', '/use-cases', '/compare', '/geo-report']);
const NON_LOCALIZED_ROUTES = new Set(['/products/compare']);

function localizeHref(href: string | undefined | null, locale: string): string {
  const str = href || '';
  if (locale === defaultLang || !str || !str.startsWith('/') || str.startsWith('//')) return str;
  const base = str.split('?')[0].split('#')[0];
  if (base === '/' || NON_LOCALIZED_ROUTES.has(base)) return str;
  if ([...LOCALIZED_ROUTES].some(r => base === r || base.startsWith(r + '/'))) {
    return '/' + locale + str;
  }
  return str;
}

const siteName = branding?.site_name?.trim() || 'Wavefella';
const year = new Date().getFullYear();
const rawCopyright = footNote ?? branding?.copyright ?? `© ${year} ${siteName} · All rights reserved.`;
const copyrightHtml = String(rawCopyright)
  .replace(/\{year\}/gi, String(year))
  .replace(/\{site_name\}/gi, siteName);
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-800 not-prose']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 dark:text-slate-300 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  >
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8 py-8 md:py-12">
      <div class="col-span-12 lg:col-span-4">
        <div class="mb-2">
          <a class="inline-block font-bold text-xl" href={localizeHref(getHomePermalink(), currentLocale)}>{siteName}</a>
        </div>
        <div class="text-sm text-muted flex gap-1">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? ' · ' : ''}
                <a
                  class="text-muted hover:text-gray-700 dark:text-gray-400 hover:underline transition duration-150 ease-in-out"
                  href={localizeHref(href, currentLocale)}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class="dark:text-gray-300 font-medium mb-2">{title}</div>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm">
                {links.map(({ text, href, ariaLabel }) => (
                  <li class="mb-2">
                    <a
                      class="text-muted hover:text-gray-700 hover:underline dark:text-gray-400 transition duration-150 ease-in-out"
                      href={localizeHref(href, currentLocale)}
                      aria-label={ariaLabel}
                      data-entity={entityForHref(href)}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
    <div class="md:flex md:items-center md:justify-between py-6 md:py-8">
      {
        mergedSocialLinks?.length ? (
          <ul class="flex mb-4 md:order-1 -ml-2 md:ml-4 md:mb-0 rtl:ml-0 rtl:-mr-2 rtl:md:ml-0 rtl:md:mr-4">
            {mergedSocialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class="text-sm mr-4 dark:text-muted">
        <Fragment set:html={copyrightHtml} />
      </div>
    </div>
  </div>
</footer>
