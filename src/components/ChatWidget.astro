---
import branding from '~/data/site/branding.yaml';

const siteName = (branding?.site_name ?? 'Wavefella').toString();
const phoneRaw = (branding?.whatsapp_number || '').toString().replace(/[^\d+]/g, '');
const defaultMessage = (branding?.whatsapp_default_message || '').toString();
const contactEmail = (branding?.contact_email_to || '').toString().trim();
---

<div data-chat-widget class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-2">
  <div
    data-chat-panel
    class="hidden w-80 max-w-[calc(100vw-2rem)] bg-white dark:bg-gray-950 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-800 overflow-hidden"
    role="dialog"
    aria-label="Contact Us"
  >
    <div class="bg-blue-600 text-white px-4 py-3 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <div class="font-semibold text-sm">Online Support</div>
        <div class="text-xs text-white/80">{siteName}</div>
      </div>
      <button
        type="button"
        data-chat-close
        aria-label="Close"
        class="text-white/80 hover:text-white"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <div class="p-4 space-y-3 max-h-96 overflow-y-auto">
      <div class="bg-gray-100 dark:bg-gray-900 rounded-lg p-3 text-sm text-gray-700 dark:text-gray-300">
        Hello 👋 How can we help? You can reach us through the options below. We usually respond within a few hours.
      </div>
      <div class="grid gap-2">
        <a
          href="/contact"
          class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-blue-950/30 transition text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600 dark:text-blue-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 7-10 5L2 7" />
          </svg>
          <div class="flex-1 min-w-0">
            <div class="font-medium">Contact Form</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">First Name / E-mail / Message</div>
          </div>
        </a>
        {contactEmail && (
          <a
            href={`mailto:${contactEmail}`}
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-blue-950/30 transition text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600 dark:text-blue-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            <div class="flex-1 min-w-0">
              <div class="font-medium">Send Email</div>
              <div class="text-xs text-gray-500 dark:text-gray-400 truncate">{contactEmail}</div>
            </div>
          </a>
        )}
        {phoneRaw && (
          <a
            href={`https://wa.me/${encodeURIComponent(phoneRaw)}${defaultMessage ? `?text=${encodeURIComponent(defaultMessage)}` : ''}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-green-400 dark:hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-950/30 transition text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-600 dark:text-green-400 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413" />
            </svg>
            <div class="flex-1 min-w-0">
              <div class="font-medium">WhatsApp</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Open in browser</div>
            </div>
          </a>
        )}
      </div>
      <textarea
        data-chat-input
        rows="2"
        placeholder="(Optional) Type your message..."
        class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 resize-none"
      ></textarea>
      <button
        type="button"
        data-chat-send
        class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 rounded-md"
      >
        Send Message
      </button>
      <p class="text-[11px] text-gray-500 dark:text-gray-400 leading-relaxed">
        Clicking the button will open the appropriate app by priority (WhatsApp —Email); if neither is configured, it navigates to the contact form.
      </p>
    </div>
  </div>
  <button
    type="button"
    data-chat-toggle
    aria-label="Open chat"
    class="w-14 h-14 rounded-full bg-blue-600 hover:bg-blue-700 text-white shadow-lg flex items-center justify-center transition-transform hover:scale-105"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
    </svg>
  </button>
</div>

<script is:inline define:vars={{ phoneRaw, contactEmail, defaultMessage }}>
  (function () {
    const widget = document.querySelector('[data-chat-widget]');
    if (!widget) return;
    const toggle = widget.querySelector('[data-chat-toggle]');
    const panel = widget.querySelector('[data-chat-panel]');
    const close = widget.querySelector('[data-chat-close]');
    const send = widget.querySelector('[data-chat-send]');
    const input = widget.querySelector('[data-chat-input]');
    if (!toggle || !panel || !close || !send || !input) return;

    function open() {
      panel.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      setTimeout(() => { try { input.focus({ preventScroll: true }); } catch {} }, 50);
    }
    function closePanel() {
      panel.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    }
    toggle.addEventListener('click', function () {
      panel.classList.contains('hidden') ? open() : closePanel();
    });
    close.addEventListener('click', closePanel);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) closePanel();
    });
    send.addEventListener('click', function () {
      const msg = (input.value || '').trim();
      if (phoneRaw) {
        const url = 'https://wa.me/' + encodeURIComponent(phoneRaw) + (msg ? '?text=' + encodeURIComponent(msg) : (defaultMessage ? '?text=' + encodeURIComponent(defaultMessage) : ''));
        window.open(url, '_blank', 'noopener,noreferrer');
        return;
      }
      if (contactEmail) {
        const body = msg || defaultMessage || 'Hello, I would like to inquire.';
        const url = 'mailto:' + encodeURIComponent(contactEmail) + '?subject=' + encodeURIComponent('Message from website') + '&body=' + encodeURIComponent(body);
        window.location.href = url;
        return;
      }
      window.location.href = '/contact';
    });
  })();
</script>
