---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(0 56 108);
    --aw-color-secondary: rgb(0 76 140);
    --aw-color-accent: rgb(0 150 199);

    --aw-color-text-heading: rgb(22 26 30);
    --aw-color-text-default: rgb(48 52 56);
    --aw-color-text-muted: rgb(96 100 106 / 72%);
    --aw-color-bg-page: rgb(250 251 253);

    --aw-color-bg-page-dark: rgb(8 12 30);

    ::selection {
      background-color: rgb(0 150 199 / 20%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(0 130 199);
    --aw-color-secondary: rgb(0 110 175);
    --aw-color-accent: rgb(0 180 216);

    --aw-color-text-heading: rgb(240 242 245);
    --aw-color-text-default: rgb(220 224 230);
    --aw-color-text-muted: rgb(180 185 195 / 72%);
    --aw-color-bg-page: rgb(8 12 30);

    ::selection {
      background-color: rgb(0 180 216 / 30%);
    }
  }
</style>
