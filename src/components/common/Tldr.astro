---
export interface Props {
  summary: string;
  points?: string[];
  className?: string;
}
const { summary, points, className = '' } = Astro.props;
---

<section class="tldr bg-blue-50/80 dark:bg-slate-800/50 border-l-4 border-blue-500 rounded-r-xl px-6 py-5 {className}" aria-label="TLDR summary" data-ai-block="tldr">
  <div class="flex items-start gap-3">
    <span class="text-blue-600 dark:text-blue-400 text-xs font-semibold uppercase tracking-wider flex-shrink-0 mt-0.5">TLDR</span>
    <div class="space-y-2 text-sm text-gray-700 dark:text-slate-300 leading-relaxed">
      <p>{summary}</p>
      {points && points.length > 0 && (
        <ul class="list-disc list-inside space-y-1 text-gray-600 dark:text-slate-400">
          {points.map(p => <li>{p}</li>)}
        </ul>
      )}
    </div>
  </div>
</section>
