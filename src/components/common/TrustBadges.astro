---
interface Badge {
  icon?: string;
  title: string;
  desc: string;
  variant?: 'cert' | 'material' | 'warranty' | 'standard';
}

export interface Props {
  badges?: Badge[];
  layout?: 'grid' | 'row' | 'compact';
  bg?: string;
  title?: string;
  subtitle?: string;
}

const defaultBadges: Badge[] = [
  { icon: '✓', title: 'ISO & CE Certified', desc: 'Every product meets international safety and quality standards.', variant: 'cert' },
  { icon: '✓', title: 'Material Excellence', desc: 'Premium PVC and Hypalon fabrics tested for UV, abrasion, and temperature extremes.', variant: 'material' },
  { icon: '✓', title: 'Rigorous Testing', desc: 'Each vessel undergoes pressure, buoyancy, and load tests before shipment.', variant: 'standard' },
  { icon: '✓', title: '2-Year Warranty', desc: 'All Wavefella products backed by comprehensive manufacturer warranty.', variant: 'warranty' },
];

const { badges = defaultBadges, layout = 'grid', bg = 'bg-white', title, subtitle } = Astro.props;
---

{
  layout === 'compact' ? (
    <div class="flex flex-wrap gap-3 {bg}">
      {badges.map(b => (
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-50 dark:bg-slate-800 dark:text-slate-300 rounded-full border border-gray-200 dark:border-slate-700">
          {b.icon && <span class="text-gray-400">{b.icon}</span>}
          {b.title}
        </span>
      ))}
    </div>
  ) : layout === 'row' ? (
    <div class="flex flex-wrap gap-4 {bg}">
      {badges.map(b => (
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/50 flex-1 min-w-[200px]">
          <div class="w-10 h-10 rounded-lg bg-sky-50 dark:bg-sky-900/30 flex items-center justify-center flex-shrink-0 text-sky-600 dark:text-sky-400 text-sm font-bold">
            {b.icon || b.variant?.[0]?.toUpperCase() || '✓'}
          </div>
          <div>
            <div class="text-sm font-semibold text-gray-900 dark:text-slate-100">{b.title}</div>
            <div class="text-xs text-gray-500 dark:text-slate-400 mt-0.5">{b.desc}</div>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <section class="py-16 {bg}">
      <div class="max-w-6xl mx-auto px-6">
        {(title || subtitle) && (
          <div class="text-center max-w-3xl mx-auto mb-12">
            {title && <h2 class="text-3xl md:text-4xl font-semibold text-gray-900 dark:text-slate-100">{title}</h2>}
            {subtitle && <p class="mt-3 text-lg text-gray-500 dark:text-slate-400">{subtitle}</p>}
          </div>
        )}
        <div class="grid md:grid-cols-4 gap-6">
          {badges.map(b => (
            <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
              <div class="w-12 h-12 bg-sky-50 dark:bg-sky-900/30 rounded-xl flex items-center justify-center mx-auto text-sky-600 dark:text-sky-400 text-lg font-bold">
                {b.icon || '✓'}
              </div>
              <h3 class="mt-4 font-semibold text-gray-900 dark:text-slate-100">{b.title}</h3>
              <p class="text-gray-500 dark:text-slate-400 mt-2 text-sm">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
