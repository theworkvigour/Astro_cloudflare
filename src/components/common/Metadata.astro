---
import merge from 'lodash.merge';
import { SEO } from 'astro-seo';

import type { SEOProps } from 'astro-seo';

import { SITE, METADATA, I18N } from 'astrowind:config';
import type { MetaData, MetaDataOpenGraph } from '~/types';
import { getCanonical } from '~/utils/permalinks';

import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
  seoSettings?: {
    siteUrl?: string;
    defaultOgImage?: { src?: string; alt?: string } | null;
    keywords?: string[];
    robotsIndex?: boolean;
    robotsFollow?: boolean;
    twitterHandle?: string;
    twitterSite?: string;
    twitterCardType?: string;
  };
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
  seoSettings = {},
} = Astro.props;

const mergedOg: MetaDataOpenGraph = merge(
  {
    url: canonical,
    siteName: SITE?.name,
    images: [],
    locale: I18N?.language || 'en',
    type: 'website',
  },
  METADATA?.openGraph,
  { url: canonical, ...openGraph }
);

const adaptedOg = await adaptOpenGraphImages(mergedOg, Astro.site);

const firstImage = adaptedOg?.images?.[0];

function buildOpenGraph(og: MetaDataOpenGraph): SEOProps['openGraph'] | undefined {
  if (!og) return undefined;

  const imageUrl = firstImage?.url || '';
  if (!imageUrl) return undefined;

  return {
    basic: {
      title: title || METADATA?.title?.default || '',
      type: og.type || 'website',
      image: imageUrl,
      url: og.url,
    },
    optional: {
      description: description || METADATA?.description,
      locale: og.locale,
      siteName: og.siteName,
    },
    image: {
      url: imageUrl,
      width: firstImage?.width,
      height: firstImage?.height,
      alt: title || METADATA?.title?.default || '',
    },
  };
}

const mergedTwitter = merge(
  {
    card: (adaptedOg?.images?.length ? 'summary_large_image' : 'summary') as 'summary_large_image' | 'summary',
  },
  METADATA?.twitter
    ? {
        card: METADATA.twitter.cardType as 'summary_large_image' | 'summary' | undefined,
        site: METADATA.twitter.site,
        creator: METADATA.twitter.handle,
      }
    : {},
  twitter
    ? {
        card: twitter.cardType as 'summary_large_image' | 'summary' | undefined,
        site: twitter.site,
        creator: twitter.handle,
      }
    : {},
  seoSettings?.twitterCardType || seoSettings?.twitterHandle || seoSettings?.twitterSite
    ? {
        card: (seoSettings.twitterCardType || 'summary_large_image') as 'summary_large_image' | 'summary',
        site: seoSettings.twitterSite,
        creator: seoSettings.twitterHandle,
      }
    : {}
);

const resolveNoindex = (): boolean => {
  if (typeof robots?.index === 'boolean') return !robots.index;
  if (typeof METADATA?.robots?.index === 'boolean') return !METADATA.robots.index;
  if (typeof seoSettings?.robotsIndex === 'boolean') return !seoSettings.robotsIndex;
  return false;
};
const resolveNofollow = (): boolean => {
  if (typeof robots?.follow === 'boolean') return !robots.follow;
  if (typeof METADATA?.robots?.follow === 'boolean') return !METADATA.robots.follow;
  if (typeof seoSettings?.robotsFollow === 'boolean') return !seoSettings.robotsFollow;
  return false;
};

// Avoid double-branding: if the title already contains the site name,
// skip the template (e.g. "OARS Pump Set —?Wavefella" + "%s —?Wavefella"
// would produce "OARS Pump Set —?Wavefella —?Wavefella").
const siteBrand = SITE?.name || 'Wavefella';
const rawTitle = title || METADATA?.title?.default || '';
const titleAlreadyBranded = rawTitle.includes(siteBrand);

const seoProps: SEOProps = {
  title: rawTitle,
  titleTemplate: ignoreTitleTemplate || titleAlreadyBranded ? '%s' : METADATA?.title?.template || '%s',
  canonical: canonical,
  noindex: resolveNoindex(),
  nofollow: resolveNofollow(),
  description: description || METADATA?.description,
  openGraph: buildOpenGraph(adaptedOg),
  twitter: mergedTwitter,
  surpressWarnings: true,
  extend: {
    meta: [
      { name: 'theme-color', content: '#0f172a' },
      { name: 'format-detection', content: 'telephone=no' },
    ],
  },
};
---

<SEO {...seoProps} />
