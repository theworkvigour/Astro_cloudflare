---
import '~/assets/styles/tailwind.css';

import { I18N, SITE_SETTINGS } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import AIChat from '~/components/widgets/AIChat.astro';
import JsonLd from '~/components/common/JsonLd.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';
import { getSeoSettings } from '~/utils/seo-settings';
import langData from '~/data/site/languages.yaml';
import { defaultLang } from '~/i18n/config';
import { getLangFromUrl, removeLang, localizePath } from '~/i18n/utils';
export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;

const seo = await getSeoSettings();

const orgName = seo.organizationName || SITE_SETTINGS.organization?.name || SITE_SETTINGS.siteName;
const orgLogo = seo.organizationLogo || SITE_SETTINGS.organization?.logo || new URL('/favicon.svg', seo.siteUrl).toString();
const sameAs = (seo.socialLinks || [])
  .map((s) => s?.url)
  .filter((u): u is string => typeof u === 'string' && u.length > 0);

const siteUrlTrimmed = seo.siteUrl.replace(/\/+$/, '');

const enabledLangs = (Array.isArray(langData) ? langData : []).filter((l: any) => l.enabled !== false);

const hostname = Astro.url.hostname;
const isSubdomain = hostname.split('.').length >= 3 && hostname !== 'localhost';
const pathname = Astro.url.pathname;
const pathWithoutLang = removeLang(pathname);
const currentLang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} seoSettings={seo} />
    <SiteVerification id={seo.googleSiteVerificationId} />
    <Analytics id={seo.googleAnalyticsId} />

    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    {
      enabledLangs.map((l: any) => (
        <link
          rel="alternate"
          hreflang={l.locale}
          href={isSubdomain
            ? `${Astro.url.protocol}//${l.locale}.${hostname.split('.').slice(1).join('.')}${pathWithoutLang}`
            : `${siteUrlTrimmed}${localizePath(pathWithoutLang, l.locale)}`
          }
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={isSubdomain
        ? `${Astro.url.protocol}//en.${hostname.split('.').slice(1).join('.')}${pathWithoutLang}`
        : `${siteUrlTrimmed}${localizePath(pathWithoutLang, defaultLang)}`
      }
    />

    <JsonLd type="Organization" data={{
      name: orgName,
      url: seo.siteUrl,
      logo: orgLogo,
      description: SITE_SETTINGS.siteDescription,
      ...(seo.organizationEmail ? { email: seo.organizationEmail } : {}),
      ...(seo.organizationPhone ? { telephone: seo.organizationPhone } : {}),
      ...(seo.organizationAddress ? { address: seo.organizationAddress } : {}),
      ...(sameAs.length > 0 ? { sameAs } : {}),
    }} />
    <JsonLd type="WebSite" data={{
      name: SITE_SETTINGS.siteName || orgName,
      url: seo.siteUrl,
      description: SITE_SETTINGS.siteDescription,
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${siteUrlTrimmed}/search?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    }} />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />
    <AIChat />
    <script>
      (function(){if(!window.IntersectionObserver)return;var e=document.querySelectorAll('.reveal');if(!e.length)return;var o=new IntersectionObserver(function(n){n.forEach(function(n){n.isIntersecting&&(n.target.classList.add('visible'),o.unobserve(n.target))})},{threshold:.15});e.forEach(function(e){o.observe(e)})})();
    </script>
  </body>
</html>
